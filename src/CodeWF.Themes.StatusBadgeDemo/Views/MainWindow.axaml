<u:UrsaWindow
    x:Class="CodeWF.Themes.StatusBadgeDemo.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:CodeWF.Themes.StatusBadgeDemo.Pages"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="using:CodeWF.Themes.StatusBadgeDemo.ViewModels"
    Title="StatusBadge 状态徽章示例"
    d:DesignHeight="780"
    d:DesignWidth="1180"
    prism:ViewModelLocator.AutoWireViewModel="True"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/logo.png"
    mc:Ignorable="d">
    <u:UrsaWindow.Resources>
        <Color x:Key="CaptionButtonForeground">#FFFFFF</Color>
        <SolidColorBrush x:Key="PanelBorderBrush">#DCE3EE</SolidColorBrush>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="16"
                          Color="#22000000"
                          OffsetX="0"
                          OffsetY="6"
                          Opacity="0.9" />
    </u:UrsaWindow.Resources>

    <u:UrsaWindow.LeftContent>
        <Grid Height="40" Margin="3" ColumnDefinitions="Auto,Auto">
            <Image Width="24"
                   Height="24"
                   Margin="8,8,4,8"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   Source="/Assets/logo.png" />
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="White"
                       IsHitTestVisible="False"
                       Text="StatusBadge 状态徽章示例" />
        </Grid>
    </u:UrsaWindow.LeftContent>

    <u:UrsaWindow.Styles>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,12" />
        </Style>
    </u:UrsaWindow.Styles>

    <Border Background="#F4F7FB">
        <Grid Margin="22" RowDefinitions="Auto,*" RowSpacing="18">
            <Border Padding="28"
                    Classes="Panel"
                    Background="#0F172A">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="StatusBadge 状态徽章示例" />
                        <TextBlock MaxWidth="760"
                                   Foreground="#CBD5E1"
                                   Text="围绕状态徽章组件展示尺寸、圆角、密度与业务应用场景，适合作为轻量信息标识控件的开源样板工程。" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                        <Border Padding="12,6" Background="#1D4ED855" CornerRadius="999">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="紧凑界面" />
                        </Border>
                        <Border Padding="12,6" Background="#0F766E55" CornerRadius="999">
                            <TextBlock Foreground="White" FontWeight="SemiBold" Text="状态标记" />
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Border Padding="16" Background="#F8FBFF" CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="统一状态色" />
                                <TextBlock Foreground="#64748B" Text="覆盖调试、信息、警告、错误和严重等标准状态语义。" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Padding="16" Background="#F8FBFF" CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="自定义密度" />
                                <TextBlock Foreground="#64748B" Text="可调整大小、圆角和内边距，以适配不同信息密度界面。" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Padding="16" Background="#F8FBFF" CornerRadius="16">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="业务落地" />
                                <TextBlock Foreground="#64748B" Text="适用于数据统计、任务跟踪、告警提示与系统健康状态标记。" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Classes="Panel" Padding="14" Effect="{StaticResource CardShadow}">
                <TabControl Background="Transparent">
                    <TabItem Header="StatusBadge 展示">
                        <pages:StatusBadgeDemo />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Border>
</u:UrsaWindow>
