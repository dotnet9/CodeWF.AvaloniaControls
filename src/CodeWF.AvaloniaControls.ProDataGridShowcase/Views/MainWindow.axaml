<Window
    x:Class="CodeWF.AvaloniaControls.ProDataGridShowcase.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.Views.Pages"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.ViewModels"
    prism:ViewModelLocator.AutoWireViewModel="True"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    Title="ProDataGrid 开源展示馆"
    Width="1280"
    Height="860"
    Background="#F3F6FB"
    FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
    WindowStartupLocation="CenterScreen"
    d:DesignHeight="860"
    d:DesignWidth="1280"
    Icon="/Assets/logo.ico"
    mc:Ignorable="d">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush">#DCE3EE</SolidColorBrush>
        <LinearGradientBrush x:Key="HeroBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B132B" Offset="0" />
            <GradientStop Color="#14532D" Offset="0.52" />
            <GradientStop Color="#0EA5E9" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="CornerRadius" Value="12,12,0,0" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid Margin="22" RowDefinitions="Auto,*" RowSpacing="18">
        <Border Padding="28"
                CornerRadius="24"
                Background="{StaticResource HeroBackground}">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="18">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <Border Width="48" Height="48" CornerRadius="14" Background="#1E293B">
                        <Image Width="28"
                               Height="28"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               Source="/Assets/logo.png" />
                    </Border>
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="CodeWF ProDataGrid 展示馆" />
                        <TextBlock Foreground="#BFDBFE"
                                   Text="Avalonia 12 开源 ProDataGrid 功能展示线" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                        <TextBlock FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                                   Text="ProDataGrid 开源功能展示馆" />
                    <TextBlock MaxWidth="760"
                               FontSize="14"
                               Foreground="#DCFCE7"
                               Text="基于 MIT 协议的 ProDataGrid 构建，专门演示三态排序、分组表头和动态列能力，适合在 Avalonia 12 主线上继续使用开源表格方案。" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Grid.RowSpan="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Top">
                    <Border Padding="12,6" Background="#064E3B55" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Avalonia 12" />
                    </Border>
                    <Border Padding="12,6" Background="#1D4ED855" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="MIT 开源" />
                    </Border>
                    <Border Padding="12,6" Background="#7C2D1255" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="高性能滚动" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="2"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                    <Border Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Foreground="#0F172A" Text="排序行为" />
                            <TextBlock Foreground="#64748B" Text="保留你现有的三态排序扩展，继续支持升序、降序和取消排序。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Foreground="#0F172A" Text="复杂表头" />
                            <TextBlock Foreground="#64748B" Text="适合工业监控、参数配置和流程看板等复杂字段场景。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Foreground="#0F172A" Text="动态列更新" />
                            <TextBlock Foreground="#64748B" Text="在保持滚动与切换体验的同时，支持运行时追加列和持续刷新数据。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="Panel" Padding="14">
            <TabControl CornerRadius="12,12,0,0"
                        TabStripPlacement="Top">
                <TabControl.Styles>
                    <Style Selector="TabControl">
                        <Setter Property="Background" Value="#55FFFFFF" />
                    </Style>
                </TabControl.Styles>

                <TabItem Header="三态排序">
                    <pages:SortingView Margin="10" Padding="10" />
                </TabItem>
                <TabItem Header="分组表头">
                    <pages:CrossRowsAndColumnsView Margin="10" Padding="10" />
                </TabItem>
                <TabItem Header="动态列">
                    <pages:DynamicColumnsView Margin="10" Padding="10" />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
