<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.Models"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.ViewModels.Pages"
             x:Class="CodeWF.AvaloniaControls.ProDataGridShowcase.Views.Pages.SortingView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:CompileBindings="False"
             x:DataType="vm:SortingViewModel"
             Background="White"
             d:DesignWidth="800"
             d:DesignHeight="450"
             mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="#F8FAFC"
                BorderBrush="#E4E9F2"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="排序方式对比" />
                <TextBlock Foreground="#5B6472"
                           Text="第一个页签展示默认的两态排序行为，第二个页签启用自定义三态排序扩展，使同一列可在升序、降序和取消排序之间循环切换。" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="默认两态">
                <DataGrid x:Name="DefaultStudentDataGrid" ItemsSource="{Binding Students}" />
            </TabItem>

            <TabItem Header="自定义三态">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <Border Padding="12"
                            Background="#F8FAFC"
                            BorderBrush="#E4E9F2"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Classes="Success"
                                    x:Name="EnableTriStateSortingButton"
                                    Content="启用 AddSorting 扩展"
                                    Click="EnableTriStateSortingButton_Click" />
                            <TextBlock Foreground="#5B6472"
                                       VerticalAlignment="Center"
                                       Text="启用扩展后，重复点击同一列表头会依次切换为升序、降序和取消排序。" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="StudentDataGrid" ItemsSource="{Binding Students}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

