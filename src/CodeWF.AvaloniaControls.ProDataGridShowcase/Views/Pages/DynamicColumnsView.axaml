<UserControl
    x:Class="CodeWF.AvaloniaControls.ProDataGridShowcase.Views.Pages.DynamicColumnsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.ProDataGridShowcase.ViewModels.Pages"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    x:CompileBindings="True"
    x:DataType="vm:DynamicColumnsViewModel"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Colors.Border.BorderBrush">#F0F0F0</SolidColorBrush>
        <SolidColorBrush x:Key="DataGridColumnHeaderForeground">#262626</SolidColorBrush>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TextBlock.Header">
            <Setter Property="Foreground" Value="#262626" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="20 0" />
        </Style>
        <Style Selector="TextBlock.Content">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="20 0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="#F8FAFC"
                BorderBrush="#E4E9F2"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="动态列" />
                <TextBlock Foreground="#5B6472"
                           Text="左侧首列保持固定，右侧指标列在运行时动态生成并持续刷新，适合控制台和监控看板场景。" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" x:Name="MyDataGrid" ItemsSource="{Binding DynamicGroups}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="116">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,-23,0" ColumnDefinitions="*,*" RowDefinitions="*,*">
                                <Path Grid.RowSpan="2"
                                      Grid.ColumnSpan="2"
                                      Data="M 0 0 L 1 1"
                                      Stretch="Fill"
                                      Stroke="#D0D8E5"
                                      StrokeThickness="1" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="20,0,0,4"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Classes="Header"
                                           FontSize="12"
                                           Text="状态" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="0,4,20,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Classes="Header"
                                           FontSize="12"
                                           Text="参数" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:DynamicGroup">
                            <Grid>
                                <TextBlock Classes="Content" Text="{Binding Name}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

