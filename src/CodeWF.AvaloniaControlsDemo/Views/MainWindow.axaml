<codewf:CodeWFWindow
    x:Class="CodeWF.AvaloniaControlsDemo.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="https://codewf.com"
    xmlns:lang="clr-namespace:Lang.Avalonia;assembly=Lang.Avalonia"
    xmlns:mainLangs="clr-namespace:Showcase.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CodeWF.AvaloniaControlsDemo.ViewModels"
    Title="{i18n:I18n {x:Static mainLangs:MainWindow.Title}}"
    Width="1280"
    Height="860"
    Background="{DynamicResource ShowcaseAppBackground}"
    FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
    TitleBarBackground="{DynamicResource ShowcaseTitleBarBackground}"
    TitleBarBorderBrush="{DynamicResource ShowcaseTitleBarBorderBrush}"
    TitleBarForeground="{DynamicResource ShowcaseTitleBarForeground}"
    TitleBarHeight="60"
    WindowStartupLocation="CenterScreen"
    d:DesignHeight="860"
    d:DesignWidth="1280"
    Icon="/Assets/logo.ico"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">
    <codewf:CodeWFWindow.DataContext>
        <vm:MainWindowViewModel />
    </codewf:CodeWFWindow.DataContext>

    <codewf:CodeWFWindow.Resources>
        <DataTemplate x:Key="LanguageSelectionTemplate" x:DataType="lang:LocalizationLanguage">
            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                <Run FontWeight="SemiBold" Text="{Binding DisplayName}" />
                <Run Text=" " />
                <Run Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="{Binding DisplayTag}" />
            </TextBlock>
        </DataTemplate>
        <DataTemplate x:Key="LanguageOptionTemplate" x:DataType="lang:LocalizationLanguage">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                <Border Grid.Column="1"
                        Padding="8,2"
                        Background="{DynamicResource ShowcaseSubtleBackground}"
                        BorderBrush="{DynamicResource ShowcaseBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="999">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                               Text="{Binding DisplayTag}" />
                </Border>
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{Binding DetailText}"
                           TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="ThemeSelectionTemplate" x:DataType="vm:ShowcaseThemeOption">
            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{Binding DisplayName}"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </codewf:CodeWFWindow.Resources>

    <codewf:CodeWFWindow.LeftContent>
        <Grid Height="60"
              ColumnDefinitions="Auto,Auto"
              IsHitTestVisible="False">
            <Border Width="34"
                    Height="34"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ShowcasePanelBackground}"
                    BorderBrush="{DynamicResource ShowcaseBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                <Image Width="22"
                       Height="22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality"
                       Source="/Assets/logo.png" />
            </Border>
            <TextBlock Grid.Column="1"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ShowcaseTitleBarForeground}"
                       Text="{i18n:I18n {x:Static mainLangs:MainWindow.AppName}}"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </codewf:CodeWFWindow.LeftContent>

    <codewf:CodeWFWindow.RightContent>
        <StackPanel Margin="0,0,8,0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Classes="Caption"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="{i18n:I18n {x:Static mainLangs:MainWindow.LanguageLabel}}" />
                <ComboBox Classes="TitleBarPicker"
                          ItemTemplate="{StaticResource LanguageOptionTemplate}"
                          ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          SelectionBoxItemTemplate="{StaticResource LanguageSelectionTemplate}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Classes="Caption"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="主题" />
                <ComboBox Classes="TitleBarPicker"
                          ItemTemplate="{StaticResource ThemeSelectionTemplate}"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                          SelectionBoxItemTemplate="{StaticResource ThemeSelectionTemplate}" />
            </StackPanel>
        </StackPanel>
    </codewf:CodeWFWindow.RightContent>

    <Border Background="{DynamicResource ShowcaseAppBackground}">
        <Border Margin="18" Classes="Panel" Padding="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="Title"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="{i18n:I18n {x:Static mainLangs:MainWindow.ControlListTitle}}" />
                        <TextBox Classes="SearchBox"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 Watermark="{i18n:I18n {x:Static mainLangs:MainWindow.SearchWatermark}}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <TabControl Background="Transparent"
                                Classes.ReverseSeparator="False"
                                IsVisible="{Binding HasMatches}"
                                ItemsSource="{Binding FilteredPages}"
                                SelectedItem="{Binding SelectedPage, Mode=TwoWay}"
                                TabStripPlacement="Left"
                                Theme="{StaticResource LineTabControl}">
                        <TabControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShowcasePageItem">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:ShowcasePageItem">
                                <ContentControl Content="{Binding Content}" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <Border Padding="24"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            IsVisible="{Binding HasNoMatches}">
                        <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                                   Text="{i18n:I18n {x:Static mainLangs:MainWindow.NoMatches}}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</codewf:CodeWFWindow>