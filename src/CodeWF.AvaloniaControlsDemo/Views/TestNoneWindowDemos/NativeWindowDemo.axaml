<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i18n="https://codewf.com"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windowLangs="clr-namespace:Showcase.Windows"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        Width="460"
        Height="320"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        WindowStartupLocation="CenterScreen"
        x:Class="CodeWF.AvaloniaControlsDemo.Views.TestNoneWindowDemos.NativeWindowDemo"
        Title="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeTitle}}">
    <Border Background="{DynamicResource ShowcaseSubtleBackground}" BorderBrush="{DynamicResource ShowcaseBorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel Spacing="8" VerticalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ShowcaseTextBrush}"
                       Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeHeading}}" />
            <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                       Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeDescription}}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>