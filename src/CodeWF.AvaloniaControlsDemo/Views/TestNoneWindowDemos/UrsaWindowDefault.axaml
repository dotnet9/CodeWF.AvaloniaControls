<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:i18n="https://codewf.com"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:windowLangs="clr-namespace:Showcase.Windows"
              mc:Ignorable="d"
              d:DesignWidth="700"
              d:DesignHeight="360"
              Width="700"
              Height="360"
              Background="{DynamicResource ShowcaseAppBackground}"
              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
              Icon="/Assets/logo.ico"
              WindowStartupLocation="CenterScreen"
              x:Class="CodeWF.AvaloniaControlsDemo.Views.TestNoneWindowDemos.UrsaWindowDefault"
              Title="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultTitle}}">
    <Border Background="{DynamicResource ShowcaseAppBackground}">
        <Grid Margin="20"
              RowDefinitions="Auto,*"
              RowSpacing="16">
            <StackPanel Spacing="6">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultHeading}}" />
                <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultDescription}}" />
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Padding="16"
                        Background="{DynamicResource ShowcaseCardBackground}"
                        BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="7">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShowcaseTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.WindowBehavior}}" />
                        <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.ResizeHotZones}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Padding="16"
                        Background="{DynamicResource ShowcaseCardBackground}"
                        BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="7">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShowcaseTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.Scenario}}" />
                        <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.ScenarioDesc}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</u:UrsaWindow>
