<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i18n="https://codewf.com"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pageLangs="clr-namespace:Showcase.Pages"
             mc:Ignorable="d"
             d:DesignWidth="920"
             d:DesignHeight="520"
             x:Class="CodeWF.AvaloniaControlsDemo.Pages.TestNoneWindowDemo">
    <UserControl.Styles>
        <Style Selector="Border.WindowDemoSection">
            <Setter Property="Background" Value="{DynamicResource ShowcaseCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShowcaseSubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
        </Style>
        <Style Selector="TextBlock.SectionCaption">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button.DemoAction">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,*" RowSpacing="14">
            <Border Padding="16"
                    Background="{DynamicResource ShowcaseSubtleBackground}"
                    BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShowcaseTextBrush}"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.Title}}" />
                        <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.Description}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="12,6"
                            VerticalAlignment="Top"
                            Background="{DynamicResource ShowcaseAccentSubtleBrush}"
                            CornerRadius="999">
                        <TextBlock Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.ShellTag}}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Classes="WindowDemoSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="SectionTitle" Text="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeGroup}}" />
                        <TextBlock Classes="SectionCaption"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeDesc}}" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.OpenNative}}"
                                Click="ShowNativeWindow_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeMove}}"
                                Click="ShowNativeWindowDraggable_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeDark}}"
                                Click="ShowNativeWindowDarkTitleBar_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeTall}}"
                                Click="ShowNativeWindowTallTitleBar_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.NativeShape}}"
                                Click="ShowNativeWindowShaped_OnClick" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="WindowDemoSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="SectionTitle" Text="{i18n:I18n {x:Static pageLangs:WindowDemo.UrsaGroup}}" />
                        <TextBlock Classes="SectionCaption"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.UrsaDesc}}" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.StandardUrsa}}"
                                Click="ShowUrsaWindow_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.UrsaTall}}"
                                Click="ShowUrsaWindowTallTitleBar_OnClick" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="WindowDemoSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="SectionTitle" Text="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFGroup}}" />
                        <TextBlock Classes="SectionCaption"
                                   Text="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFDesc}}" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.StandardCodeWF}}"
                                Click="ShowCodeWFWindowStandard_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFDark}}"
                                Click="ShowCodeWFWindowDark_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFAccent}}"
                                Click="ShowCodeWFWindowAccent_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFTall}}"
                                Click="ShowCodeWFWindowTall_OnClick" />
                        <Button Classes="DemoAction"
                                Content="{i18n:I18n {x:Static pageLangs:WindowDemo.CodeWFServiceConsole}}"
                                Click="ShowCodeWFWindowServiceConsole_OnClick" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
