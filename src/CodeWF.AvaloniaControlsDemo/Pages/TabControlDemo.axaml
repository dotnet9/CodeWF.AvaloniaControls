<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i18n="https://codewf.com"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pageLangs="clr-namespace:Showcase.Pages"
             mc:Ignorable="d"
             d:DesignWidth="920"
             d:DesignHeight="520"
             x:Class="CodeWF.AvaloniaControlsDemo.Pages.TabControlDemo">
    <Grid RowDefinitions="Auto,*,*" RowSpacing="14">
        <Border Padding="16"
                Background="{DynamicResource ShowcaseSubtleBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Title}}" />
                <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Description}}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Classes="SurfaceCard">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="PanelTitle"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BusinessStyle}}" />
                        <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BusinessContentDesc}}" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="StatusChip" VerticalAlignment="Top">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.ContentDemo}}" />
                    </Border>
                </Grid>
                <TabControl Grid.Row="1"
                            Classes="BusinessTabs"
                            SelectedIndex="0"
                            Theme="{StaticResource TrapezoidShapedTabControl}"
                            CornerRadius="10 10 0 0"
                            TabStripPlacement="Top">
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.DataManagement}}">
                        <Grid Margin="0,14,0,0"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="12">
                            <Border Padding="14"
                                    Background="{DynamicResource ShowcaseSubtleBackground}"
                                    CornerRadius="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="PanelTitle" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.DataQuality}}" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ShowcaseTextBrush}"
                                               Text="98.7%" />
                                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Last24hPassRate}}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Padding="14"
                                    Background="{DynamicResource ShowcaseSubtleBackground}"
                                    CornerRadius="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="PanelTitle" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Pending}}" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ShowcaseWarningBrush}"
                                               Text="17" />
                                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.ManualReviewRecords}}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="{DynamicResource ShowcaseSubtleBackground}"
                                    CornerRadius="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="PanelTitle" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.SyncStatus}}" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ShowcasePositiveBrush}"
                                               Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Normal}}" />
                                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.LastSync2Min}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.SystemSettings}}">
                        <TextBlock Margin="0,18,0,0"
                                   Classes="Caption"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.SettingsContentDesc}}" />
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.UserCenter}}">
                        <TextBlock Margin="0,18,0,0"
                                   Classes="Caption"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.UserCenterContentDesc}}" />
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.LogRecords}}">
                        <TextBlock Margin="0,18,0,0"
                                   Classes="Caption"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.LogRecordsContentDesc}}" />
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.HelpDocs}}">
                        <TextBlock Margin="0,18,0,0"
                                   Classes="Caption"
                                   Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.HelpDocsContentDesc}}" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Classes="SurfaceCard">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="PanelTitle"
                               Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BrandStyle}}" />
                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BrandContentDesc}}" />
                </StackPanel>
                <TabControl Grid.Row="1"
                            Classes="BrandTabs"
                            SelectedIndex="0"
                            Theme="{StaticResource TrapezoidShapedTabControl}"
                            CornerRadius="10 10 0 0"
                            TabStripPlacement="Top">
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.DataManagement}}">
                        <Border Margin="0,14,0,0"
                                Padding="16"
                                Background="{DynamicResource ShowcaseSubtleBackground}"
                                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="PanelTitle" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BrandContentTitle}}" />
                                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BrandContentBody}}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Padding="14,0"
                                        VerticalAlignment="Center"
                                        Content="{i18n:I18n {x:Static pageLangs:TabControlDemo.ViewDetails}}" />
                            </Grid>
                        </Border>
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.SystemSettings}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.UserCenter}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.LogRecords}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.HelpDocs}}" />
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>

