<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControlsDemo.ViewModels"
             xmlns:model="clr-namespace:CodeWF.AvaloniaControlsDemo.Models"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:i18n="https://codewf.com"
             xmlns:pageLangs="clr-namespace:Showcase.Pages"
             x:Class="CodeWF.AvaloniaControlsDemo.Pages.VComboBoxDemo"
             x:DataType="vm:VComboBoxDemoViewModel"
             d:DesignWidth="980"
             d:DesignHeight="520"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:VComboBoxDemoViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <x:Double x:Key="MenuFontSize">14</x:Double>
        <FontWeight x:Key="MenuFontWeight">Normal</FontWeight>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="u|IconButton">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
            <Setter Property="FontSize" Value="{StaticResource MenuFontSize}" />
            <Setter Property="FontWeight" Value="{StaticResource MenuFontWeight}" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
            <Setter Property="FontSize" Value="{StaticResource MenuFontSize}" />
            <Setter Property="FontWeight" Value="{StaticResource MenuFontWeight}" />
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate DataType="model:WarningItem">
                        <Grid ColumnDefinitions="Auto,Auto">
                            <Rectangle Grid.Column="0"
                                       Width="24"
                                       Height="24"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center"
                                       Fill="{Binding Color}" />
                            <TextBlock Grid.Column="1"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding Name}" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="SelectionBoxItemTemplate">
                <Setter.Value>
                    <DataTemplate DataType="model:WarningItem">
                        <Grid RowDefinitions="Auto,Auto" VerticalAlignment="Bottom">
                            <Rectangle Grid.Row="0"
                                       Width="24"
                                       Height="24"
                                       Margin="0,15,0,10"
                                       HorizontalAlignment="Center"
                                       Fill="{Binding Color}" />
                            <TextBlock Grid.Row="1"
                                       HorizontalAlignment="Center"
                                       Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.SelectionBoxWarning}}" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Border.SurfaceCard">
            <Setter Property="Background" Value="{DynamicResource ShowcaseCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShowcaseSubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style Selector="TextBlock.PanelTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Border.StatePill">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="{DynamicResource ShowcaseAccentSubtleBrush}" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="{DynamicResource ShowcaseSubtleBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Title}}" />
                <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Description}}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.55*,*" ColumnSpacing="14">
            <Border Classes="SurfaceCard">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="5">
                            <TextBlock Classes="PanelTitle" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.ToolbarTitle}}" />
                            <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.ToolbarDescription}}" />
                        </StackPanel>
                        <Border Grid.Column="1" Classes="StatePill" VerticalAlignment="Top">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                                       Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.LivePreview}}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Padding="14,12"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="18">
                            <u:IconButton Content="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.New}}" IconPlacement="Top" VerticalAlignment="Top" Padding="0">
                                <u:IconButton.Icon>
                                    <Rectangle Width="24" Height="24" Margin="0,0,0,-4" HorizontalAlignment="Center" Fill="#EF4444" />
                                </u:IconButton.Icon>
                            </u:IconButton>

                            <Grid>
                                <u:IconButton Content="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Configure}}" IconPlacement="Top">
                                    <u:IconButton.Icon>
                                        <Rectangle Width="24" Height="24" Margin="0,0,0,5" HorizontalAlignment="Center" Fill="#F59E0B" />
                                    </u:IconButton.Icon>
                                </u:IconButton>
                                <u:PopConfirm PopupHeader="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.PopupHeader}}" Placement="Bottom">
                                    <u:PopConfirm.PopupContent>
                                        <TextBox Watermark="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.PopupWatermark}}" />
                                    </u:PopConfirm.PopupContent>
                                    <Button VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch"
                                            MinHeight="0"
                                            Classes="Small"
                                            Theme="{DynamicResource BorderlessButton}">
                                        <PathIcon Foreground="{DynamicResource ComboBoxIconDefaultForeground}"
                                                  Data="{DynamicResource ComboBoxIcon}"
                                                  IsHitTestVisible="False"
                                                  Theme="{DynamicResource InnerPathIcon}"
                                                  UseLayoutRounding="False" />
                                    </Button>
                                </u:PopConfirm>
                            </Grid>

                            <u:IconButton Content="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Edit}}" IconPlacement="Top">
                                <u:IconButton.Icon>
                                    <Rectangle Width="24" Height="24" Margin="0,0,0,5" HorizontalAlignment="Center" Fill="#3B82F6" />
                                </u:IconButton.Icon>
                            </u:IconButton>

                            <u:IconButton Content="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Refresh}}" IconPlacement="Top">
                                <u:IconButton.Icon>
                                    <Rectangle Width="24" Height="24" Margin="0,0,0,5" HorizontalAlignment="Center" Fill="#10B981" />
                                </u:IconButton.Icon>
                            </u:IconButton>

                            <Rectangle Width="1" Height="44" Fill="{DynamicResource ShowcaseSubtleBorderBrush}" />

                            <ComboBox ItemsSource="{Binding WarningItems}"
                                      MinWidth="146"
                                      SelectedIndex="0"
                                      Theme="{StaticResource VComboBox}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="14">
                        <Border Padding="16"
                                Background="{DynamicResource ShowcaseSubtleBackground}"
                                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel Spacing="12">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShowcaseTextBrush}"
                                           Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.VerticalSelectorTitle}}" />
                                <ComboBox Width="172"
                                          HorizontalAlignment="Left"
                                          ItemsSource="{Binding WarningItems}"
                                          SelectedIndex="1"
                                          Theme="{StaticResource VComboBox}" />
                                <TextBlock Classes="Caption"
                                           Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.VerticalSelectorDescription}}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="16"
                                Background="{DynamicResource ShowcaseSubtleBackground}"
                                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="9">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShowcaseTextBrush}"
                                           Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.FilterResultTitle}}" />
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="#EF4444" />
                                    <TextBlock Grid.Column="1" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.FilterDelayed}}" />
                                    <TextBlock Grid.Column="2" Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="12" />
                                </Grid>
                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="#F59E0B" />
                                    <TextBlock Grid.Column="1" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.FilterPendingConfig}}" />
                                    <TextBlock Grid.Column="2" Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="4" />
                                </Grid>
                                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="#10B981" />
                                    <TextBlock Grid.Column="1" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.FilterNormal}}" />
                                    <TextBlock Grid.Column="2" Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="38" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="SurfaceCard">
                <StackPanel Spacing="14">
                    <TextBlock Classes="PanelTitle"
                               Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.ScenarioTitle}}" />
                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Scenario1}}" />
                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Scenario2}}" />
                    <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.Scenario3}}" />

                    <Border Margin="0,10,0,0"
                            Padding="14"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShowcaseTextBrush}"
                                       Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.CurrentPolicyTitle}}" />
                            <TextBlock Classes="Caption" Text="{i18n:I18n {x:Static pageLangs:VComboBoxDemo.CurrentPolicyDescription}}" />
                            <Border Classes="StatePill" HorizontalAlignment="Left">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                                           Text="Popover + VComboBox" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>


