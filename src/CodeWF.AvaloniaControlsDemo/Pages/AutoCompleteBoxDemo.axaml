<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i18n="https://codewf.com"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:CodeWF.AvaloniaControlsDemo.Models"
             xmlns:pageLangs="clr-namespace:Showcase.Pages"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControlsDemo.ViewModels"
             x:Class="CodeWF.AvaloniaControlsDemo.Pages.AutoCompleteBoxDemo"
             x:DataType="vm:AutoCompleteBoxDemoViewModel"
             d:DesignWidth="980"
             d:DesignHeight="560"
             mc:Ignorable="d">
    <UserControl.DataContext>
        <vm:AutoCompleteBoxDemoViewModel />
    </UserControl.DataContext>

    <UserControl.Styles>
        <Style Selector="u|AutoCompleteBox">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
        </Style>
        <Style Selector="u|AutoCompleteBox /template/ TextBox#PART_TextBox">
            <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource ShowcaseTextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource ShowcaseAccentSubtleBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource ShowcaseTextBrush}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <DataTemplate x:Key="AutoCompleteSuggestionTemplate" x:DataType="models:AutoCompleteBoxDemoSuggestion">
            <Grid MinWidth="420"
                  ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="3">
                <Border Width="28"
                        Height="28"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ShowcaseSubtleBackground}"
                        BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                               Text="{Binding DisplayIndex}" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseTextBrush}"
                               Text="{Binding DisplayName}" />
                    <TextBlock Classes="Caption"
                               FontSize="12"
                               Text="{Binding Detail}" />
                </StackPanel>
                <Border Grid.Column="2"
                        Padding="8,2"
                        VerticalAlignment="Top"
                        Background="{DynamicResource ShowcaseSubtleBackground}"
                        BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="999"
                        IsVisible="{Binding IsPinned}">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                               Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.PinnedTag}}" />
                </Border>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           FontSize="12"
                           Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{Binding Category}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SimpleAutoCompleteSuggestionTemplate" x:DataType="models:AutoCompleteBoxDemoSuggestion">
            <Grid MinWidth="320"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{Binding DisplayName}"
                           TextTrimming="CharacterEllipsis" />
                <Border Grid.Column="1"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ShowcaseSubtleBackground}"
                        BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="999"
                        IsVisible="{Binding IsPinned}">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                               Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.PinnedTag}}" />
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ShowcaseTextBrush}"
                   Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.Title}}" />

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">
            <Border Classes="SurfaceCard" DataContext="{Binding DetailedSample}">
                <StackPanel x:DataType="vm:AutoCompleteBoxSampleViewModel" Spacing="12">
                    <Grid ColumnDefinitions="*,156" ColumnSpacing="12">
                        <TextBlock Classes="PanelTitle"
                                   VerticalAlignment="Center"
                                   Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.SearchLabel}}" />
                        <StackPanel Grid.Column="1" Spacing="7">
                            <TextBlock Classes="Caption"
                                       FontWeight="SemiBold"
                                       Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.PinnedCountLabel}}" />
                            <NumericUpDown ClipValueToMinMax="True"
                                           FormatString="0"
                                           Increment="1"
                                           Maximum="{Binding MaxPinnedCount}"
                                           Minimum="0"
                                           Value="{Binding PinnedCount, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <u:AutoCompleteBox Classes="ClearButton"
                                       ItemFilter="{Binding ItemFilter}"
                                       ItemTemplate="{StaticResource AutoCompleteSuggestionTemplate}"
                                       ItemsSource="{Binding Suggestions}"
                                       MaxDropDownHeight="320"
                                       PlaceholderText="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.SearchWatermark}}"
                                       SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
                                       ValueMemberBinding="{ReflectionBinding DisplayName}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="SurfaceCard" DataContext="{Binding SimpleSample}">
                <StackPanel x:DataType="vm:AutoCompleteBoxSampleViewModel" Spacing="12">
                    <Grid ColumnDefinitions="*,156" ColumnSpacing="12">
                        <TextBlock Classes="PanelTitle"
                                   VerticalAlignment="Center"
                                   Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.SimpleSearchLabel}}" />
                        <StackPanel Grid.Column="1" Spacing="7">
                            <TextBlock Classes="Caption"
                                       FontWeight="SemiBold"
                                       Text="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.PinnedCountLabel}}" />
                            <NumericUpDown ClipValueToMinMax="True"
                                           FormatString="0"
                                           Increment="1"
                                           Maximum="{Binding MaxPinnedCount}"
                                           Minimum="0"
                                           Value="{Binding PinnedCount, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <u:AutoCompleteBox Classes="ClearButton"
                                       ItemFilter="{Binding ItemFilter}"
                                       ItemTemplate="{StaticResource SimpleAutoCompleteSuggestionTemplate}"
                                       ItemsSource="{Binding Suggestions}"
                                       MaxDropDownHeight="320"
                                       PlaceholderText="{i18n:I18n {x:Static pageLangs:AutoCompleteBoxDemo.SearchWatermark}}"
                                       SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
                                       ValueMemberBinding="{ReflectionBinding DisplayName}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
