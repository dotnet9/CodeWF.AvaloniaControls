<UserControl
    x:Class="CodeWF.AvaloniaControlsDemo.Pages.MarkupExtensionsDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:codewf="https://codewf.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="https://codewf.com"
    xmlns:local="clr-namespace:CodeWF.AvaloniaControlsDemo.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:CodeWF.AvaloniaControlsDemo.Models"
    xmlns:pageLangs="clr-namespace:Showcase.Pages"
    x:DataType="local:MarkupExtensionsDemo"
    d:DesignHeight="620"
    d:DesignWidth="980"
    mc:Ignorable="d">
    <UserControl.Resources>
        <codewf:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <SolidColorBrush x:Key="UnknownHealthBrush" Color="#F8FAFC" />

        <codewf:SwitchCases x:Key="HealthTitleCases">
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Healthy}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthHealthyTitle}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Delayed}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthDelayedTitle}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Failed}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthFailedTitle}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Locked}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthLockedTitle}}" />
        </codewf:SwitchCases>

        <codewf:SwitchCases x:Key="HealthDescriptionCases">
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Healthy}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthHealthyDesc}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Delayed}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthDelayedDesc}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Failed}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthFailedDesc}}" />
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Locked}"
                               Then="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.HealthLockedDesc}}" />
        </codewf:SwitchCases>

        <codewf:SwitchCases x:Key="HealthBrushCases">
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Healthy}">
                <codewf:SwitchCase.Then>
                    <SolidColorBrush Color="#DCFCE7" />
                </codewf:SwitchCase.Then>
            </codewf:SwitchCase>
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Delayed}">
                <codewf:SwitchCase.Then>
                    <SolidColorBrush Color="#FEF3C7" />
                </codewf:SwitchCase.Then>
            </codewf:SwitchCase>
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Failed}">
                <codewf:SwitchCase.Then>
                    <SolidColorBrush Color="#FEE2E2" />
                </codewf:SwitchCase.Then>
            </codewf:SwitchCase>
            <codewf:SwitchCase When="{x:Static models:PipelineHealth.Locked}">
                <codewf:SwitchCase.Then>
                    <SolidColorBrush Color="#E0E7FF" />
                </codewf:SwitchCase.Then>
            </codewf:SwitchCase>
        </codewf:SwitchCases>

        <codewf:IfConditionConverter x:Key="RunVisualConverter">
            <codewf:IfConditionConverter.True>
                <Border Padding="14,10"
                        Background="#DCFCE7"
                        BorderBrush="#86EFAC"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#166534"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.AutoPublishEnabled}}" />
                        <TextBlock Foreground="#15803D"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.AutoPublishEnabledDesc}}" />
                    </StackPanel>
                </Border>
            </codewf:IfConditionConverter.True>
            <codewf:IfConditionConverter.False>
                <Border Padding="14,10"
                        Background="#FEE2E2"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#991B1B"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.AutoPublishPaused}}" />
                        <TextBlock Foreground="#B91C1C"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.AutoPublishPausedDesc}}" />
                    </StackPanel>
                </Border>
            </codewf:IfConditionConverter.False>
        </codewf:IfConditionConverter>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="{DynamicResource ShowcaseSubtleBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Title}}" />
                <TextBlock Classes="Caption"
                           Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Description}}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.15*,*" ColumnSpacing="14">
            <Border Classes="Panel" Padding="18">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="SectionTitle"
                                       Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.PipelineConsole}}" />
                            <TextBlock Classes="Caption"
                                       Text="{Binding PipelineStatusText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                MinWidth="112"
                                VerticalAlignment="Top"
                                Click="TogglePipelineStatus"
                                Content="{Binding PipelineToggleText}" />
                    </Grid>

                    <ContentControl Grid.Row="1"
                                    Content="{Binding IsPipelineRunning, Converter={StaticResource RunVisualConverter}}" />

                    <Border Grid.Row="2"
                            Padding="16"
                            Background="{codewf:Switch {Binding Health}, Cases={StaticResource HealthBrushCases}, Default={StaticResource UnknownHealthBrush}}"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#0F172A"
                                           Text="{codewf:Switch {Binding Health}, Cases={StaticResource HealthTitleCases}, Default={i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.UnknownStatus}}}" />
                                <TextBlock Foreground="#334155"
                                           Text="{codewf:Switch {Binding Health}, Cases={StaticResource HealthDescriptionCases}, Default={i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.UnknownStatusDesc}}}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="NextHealth"
                                    Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.NextStatus}}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Padding="16"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource ShowcaseTextBrush}"
                                               Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.QueueTitle}}" />
                                    <TextBlock Classes="Caption"
                                               Text="{Binding QueueStatusText}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Click="ClearQueue"
                                        Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Clear}}" />
                                <Button Grid.Column="2"
                                        VerticalAlignment="Top"
                                        Click="RefillQueue"
                                        Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Reset}}" />
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding QueuedDeployments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,8"
                                                Padding="10,6"
                                                Background="{DynamicResource ShowcaseCardBackground}"
                                                BorderBrush="{DynamicResource ShowcaseBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock Foreground="{DynamicResource ShowcaseTextBrush}"
                                                       Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="Panel" Padding="18">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="5">
                        <TextBlock Classes="SectionTitle"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.SwitchSourceTitle}}" />
                        <TextBlock Classes="Caption"
                                   Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.SwitchSourceDesc}}" />
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <RadioButton Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Healthy}}"
                                     GroupName="PipelineHealth"
                                     IsChecked="{Binding Health, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PipelineHealth.Healthy}}" />
                        <RadioButton Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Delayed}}"
                                     GroupName="PipelineHealth"
                                     IsChecked="{Binding Health, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PipelineHealth.Delayed}}" />
                        <RadioButton Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Failed}}"
                                     GroupName="PipelineHealth"
                                     IsChecked="{Binding Health, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PipelineHealth.Failed}}" />
                        <RadioButton Content="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.Locked}}"
                                     GroupName="PipelineHealth"
                                     IsChecked="{Binding Health, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static models:PipelineHealth.Locked}}" />
                    </WrapPanel>

                    <Border Padding="14"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShowcaseTextBrush}"
                                       Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.CurrentXamlTitle}}" />
                            <edit:TextEditor x:Name="SwitchSnippetEditor"
                                             Height="54"
                                             Background="{DynamicResource ShowcaseCodeBackground}"
                                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                                             FontSize="13"
                                             HorizontalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             ShowLineNumbers="False"
                                             VerticalScrollBarVisibility="Disabled"
                                             WordWrap="True" />
                        </StackPanel>
                    </Border>

                    <Border Padding="14"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShowcaseTextBrush}"
                                       Text="{i18n:I18n {x:Static pageLangs:MarkupExtensionsDemo.IfSyntaxTitle}}" />
                            <edit:TextEditor x:Name="IfSnippetEditor"
                                             Height="54"
                                             Background="{DynamicResource ShowcaseCodeBackground}"
                                             FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                                             FontSize="13"
                                             HorizontalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             ShowLineNumbers="False"
                                             VerticalScrollBarVisibility="Disabled"
                                             WordWrap="True" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>