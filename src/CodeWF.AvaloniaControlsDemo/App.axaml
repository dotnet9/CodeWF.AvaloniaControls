<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CodeWF.AvaloniaControlsDemo.App"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:uSemi="https://irihi.tech/ursa/themes/semi"
             xmlns:codewf="https://codewf.com"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <fluent:FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <uSemi:SemiTheme Locale="zh-CN" />
        <codewf:ACSemiTheme />
        <StyleInclude Source="Styles/Index.axaml" />
    </Application.Styles>
</Application>
