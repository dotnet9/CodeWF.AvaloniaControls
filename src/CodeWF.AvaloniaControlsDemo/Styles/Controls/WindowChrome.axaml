<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>

    <Style Selector="Button.WindowCaptionButton">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="46" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseTitleBarForeground}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.WindowCaptionButton:pointerover">
        <Setter Property="Background" Value="#1A64748B" />
    </Style>
    <Style Selector="Button.WindowCaptionButton:pressed">
        <Setter Property="Background" Value="#2A64748B" />
    </Style>
    <Style Selector="Button.WindowShapeCloseButton">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="BorderBrush" Value="#B8FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="#E6F8FAFC" />
        <Setter Property="Foreground" Value="#111827" />
    </Style>
    <Style Selector="Button.WindowCloseButton:pointerover">
        <Setter Property="Background" Value="#E81123" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.WindowCloseButton:pressed">
        <Setter Property="Background" Value="#C50F1F" />
        <Setter Property="Foreground" Value="White" />
    </Style>
</Styles>
