<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Border.WindowDemoSection">
        <Setter Property="Background" Value="{DynamicResource ShowcaseCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ShowcaseSubtleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
    </Style>
    <Style Selector="TextBlock.SectionCaption">
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Button.DemoAction">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</Styles>