<Styles xmlns="https://github.com/avaloniaui"
        xmlns:c="https://codewf.com">
    <Style Selector="c|StatusBadge">
        <Setter Property="Margin" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
    </Style>
    <Style Selector="TextBlock.SectionDescription">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseMutedTextBrush}" />
        <Setter Property="MaxWidth" Value="760" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.SubLabel">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ShowcaseTextBrush}" />
    </Style>
</Styles>