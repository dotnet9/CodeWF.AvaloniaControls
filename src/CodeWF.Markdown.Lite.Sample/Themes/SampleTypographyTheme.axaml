<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CodeWF.Markdown.Lite.Sample.Themes.SampleTypographyThemeResources">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#0F766E" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#ECFDF5" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#ECFDF5" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#CCFBF1" />
            <SolidColorBrush x:Key="CodeWFMarkdownCodeBackgroundBrush" Color="#F1F5F9" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#5EEAD4" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#12312D" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#12312D" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#17413B" />
            <SolidColorBrush x:Key="CodeWFMarkdownCodeBackgroundBrush" Color="#0B1719" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="CodeWFMarkdownParagraphFontSize">17</x:Double>
    <x:Double x:Key="CodeWFMarkdownParagraphLineHeight">31</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading1FontSize">34</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading2FontSize">28</x:Double>
</ResourceDictionary>
