<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="https://codewf.com">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackAccentBrush" Color="#2B2D31" />
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackSoftBrush" Color="#F3F4F6" />
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackHeaderBrush" Color="#E5E7EB" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackAccentBrush" Color="#E5E7EB" />
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackSoftBrush" Color="#22252B" />
                    <SolidColorBrush x:Key="CodeWFMarkdownInkBlackHeaderBrush" Color="#2D323A" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="md|MarkdownViewer.MdThemeInkBlack">
        <Setter Property="AccentBrush" Value="{DynamicResource CodeWFMarkdownInkBlackAccentBrush}" />
        <Setter Property="QuoteBackgroundBrush" Value="{DynamicResource CodeWFMarkdownInkBlackSoftBrush}" />
        <Setter Property="InlineCodeBackgroundBrush" Value="{DynamicResource CodeWFMarkdownInkBlackSoftBrush}" />
        <Setter Property="TableHeaderBackgroundBrush" Value="{DynamicResource CodeWFMarkdownInkBlackHeaderBrush}" />
        <Setter Property="Heading1FontSize" Value="29" />
    </Style>
</Styles>
