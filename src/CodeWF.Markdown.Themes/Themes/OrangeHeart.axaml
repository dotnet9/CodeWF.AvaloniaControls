<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CodeWF.Markdown.Themes.Themes.OrangeHeartTypographyResources">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#EF7060" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#FFF3F0" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#FFF3F0" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#FFE4DF" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#FF8A75" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#3A201C" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#3A201C" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#4A2924" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
