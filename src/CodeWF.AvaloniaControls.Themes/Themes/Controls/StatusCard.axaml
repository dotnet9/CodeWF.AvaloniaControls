<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com">
    <Design.PreviewWith>
        <codewf:StatusCard
            Width="200"
            Height="80"
            TopText="CodeWF"
            BottomText="Running" />
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type codewf:StatusCard}" TargetType="codewf:StatusCard">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Template">
            <ControlTemplate TargetType="codewf:StatusCard">
                <Border
                    Background="{TemplateBinding Kind, Converter={StaticResource StatusLabelKindBackgroundConverter}}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid RowDefinitions="*,*" ColumnDefinitions="Auto,*">
                        <Image
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Width="{TemplateBinding IconWidth}"
                            Height="{TemplateBinding IconWidth}"
                            Margin="{TemplateBinding IconMargin}"
                            Source="{TemplateBinding IconPath, Converter={StaticResource String2ImageConverter}}" />
                        <SelectableTextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="{TemplateBinding TopTextMargin}"
                            VerticalAlignment="Center"
                            Foreground="#595959"
                            FontSize="{TemplateBinding TopTextFontSize}"
                            Text="{TemplateBinding TopText}" />
                        <SelectableTextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="{TemplateBinding BottomTextMargin}"
                            VerticalAlignment="Center"
                            Foreground="{TemplateBinding Kind, Converter={StaticResource StatusCardKindForegroundConverter}}"
                            FontSize="{TemplateBinding BottomTextFontSize}"
                            Text="{TemplateBinding BottomText}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
