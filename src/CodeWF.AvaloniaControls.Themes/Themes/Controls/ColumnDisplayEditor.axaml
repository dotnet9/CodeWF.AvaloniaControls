<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com">
    <Design.PreviewWith>
        <codewf:ColumnDisplayEditor Width="360" Height="420" />
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type codewf:ColumnDisplayEditor}" TargetType="codewf:ColumnDisplayEditor">
        <Setter Property="Template">
            <ControlTemplate TargetType="codewf:ColumnDisplayEditor">
                <Border
                    Background="{DynamicResource ColumnDisplayEditorBackground}"
                    BorderBrush="{DynamicResource ColumnDisplayEditorBorderBrush}"
                    BorderThickness="{StaticResource SemiBorderThicknessControl}"
                    CornerRadius="{StaticResource SemiBorderRadiusMedium}">
                    <Grid RowDefinitions="34,*">
                        <Border
                            Background="{DynamicResource ColumnDisplayEditorHeaderBackground}"
                            BorderBrush="{DynamicResource ColumnDisplayEditorBorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                            <Grid ColumnDefinitions="38,72,*" Margin="8,0,12,0">
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ColumnDisplayEditorHeaderForeground}"
                                    Text="{TemplateBinding VisibleHeaderText}" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ColumnDisplayEditorHeaderForeground}"
                                    Text="{TemplateBinding DisplayTextHeaderText}" />
                            </Grid>
                        </Border>

                        <ListBox
                            Name="PART_ListBox"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{TemplateBinding ItemsSource}"
                            SelectionMode="Single">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="6,2" />
                                    <Setter Property="MinHeight" Value="34" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="CornerRadius" Value="{StaticResource SemiBorderRadiusMedium}" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource ColumnDisplayEditorRowHoverBackground}" />
                                </Style>
                                <Style Selector="ListBoxItem:selected">
                                    <Setter Property="Background" Value="{DynamicResource ColumnDisplayEditorRowSelectedBackground}" />
                                </Style>
                                <Style Selector="ListBoxItem.drop-before">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ColumnDisplayEditorDropPreviewBrush}" />
                                    <Setter Property="BorderThickness" Value="0,2,0,0" />
                                </Style>
                                <Style Selector="ListBoxItem.drop-after">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ColumnDisplayEditorDropPreviewBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:CompileBindings="False">
                                    <Grid ColumnDefinitions="38,72,*" MinHeight="34">
                                        <Button
                                            Name="PART_DragHandle"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="SizeAll"
                                            Foreground="{DynamicResource ColumnDisplayEditorDragHandleForeground}">
                                            <PathIcon
                                                Width="15"
                                                Height="15"
                                                Data="{StaticResource SemiIconHandle}" />
                                        </Button>
                                        <CheckBox
                                            Grid.Column="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding Visible, Mode=TwoWay}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource ColumnDisplayEditorRowForeground}"
                                            Text="{Binding DisplayText}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
