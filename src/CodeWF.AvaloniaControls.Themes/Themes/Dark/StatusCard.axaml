<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="StatusCardTopTextForeground" ResourceKey="SemiColorText2" />
    <StaticResource x:Key="StatusCardDebugBackground" ResourceKey="SemiColorInformationLight" />
    <StaticResource x:Key="StatusCardInfoBackground" ResourceKey="SemiColorSuccessLight" />
    <StaticResource x:Key="StatusCardWarnBackground" ResourceKey="SemiColorWarningLight" />
    <StaticResource x:Key="StatusCardErrorBackground" ResourceKey="SemiColorDangerLight" />
    <StaticResource x:Key="StatusCardFatalBackground" ResourceKey="SemiColorDangerLightActive" />
    <StaticResource x:Key="StatusCardDebugForeground" ResourceKey="SemiColorText0" />
    <StaticResource x:Key="StatusCardInfoForeground" ResourceKey="SemiColorText0" />
    <StaticResource x:Key="StatusCardWarnForeground" ResourceKey="SemiColorWarning" />
    <StaticResource x:Key="StatusCardErrorForeground" ResourceKey="SemiColorDanger" />
    <StaticResource x:Key="StatusCardFatalForeground" ResourceKey="SemiColorDangerActive" />
</ResourceDictionary>
