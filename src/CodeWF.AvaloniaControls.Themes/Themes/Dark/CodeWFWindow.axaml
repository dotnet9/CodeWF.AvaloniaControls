<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="CodeWFWindowBackground" ResourceKey="WindowDefaultBackground" />
    <StaticResource x:Key="CodeWFWindowForeground" ResourceKey="WindowDefaultForeground" />
    <StaticResource x:Key="CodeWFWindowTitleBarBackground" ResourceKey="TitleBarBackground" />
    <StaticResource x:Key="CodeWFWindowTitleBarForeground" ResourceKey="CaptionButtonForeground" />
    <StaticResource x:Key="CodeWFWindowTitleBarBorderBrush" ResourceKey="WindowBorderBrush" />
</ResourceDictionary>