<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="CodeWFWindowTitleBarHeight" ResourceKey="SemiHeightControlDefault" />
    <StaticResource x:Key="CodeWFWindowCornerRadius" ResourceKey="SemiBorderRadiusSmall" />
    <StaticResource x:Key="CodeWFWindowBorderThickness" ResourceKey="SemiBorderThicknessControl" />
    <StaticResource x:Key="CodeWFWindowTitleBarBorderThickness" ResourceKey="SemiBorderThickness" />
    <StaticResource x:Key="CodeWFWindowTitleBarContentPadding" ResourceKey="SemiThicknessNone" />
    <x:Double x:Key="CodeWFWindowResizeGripThickness">5</x:Double>
    <x:Double x:Key="CodeWFWindowResizeGripCornerSize">10</x:Double>
</ResourceDictionary>