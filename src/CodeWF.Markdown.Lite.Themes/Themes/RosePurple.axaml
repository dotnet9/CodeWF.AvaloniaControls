<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CodeWF.Markdown.Lite.Themes.Themes.RosePurpleTypographyResources">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#C1467B" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#FFF0F6" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#FFF0F6" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#FCE1ED" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#F472B6" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#3C1B2A" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#3C1B2A" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#52253A" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
