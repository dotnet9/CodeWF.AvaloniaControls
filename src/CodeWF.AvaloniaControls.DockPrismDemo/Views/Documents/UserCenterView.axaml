<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.DockPrismDemo.ViewModels.Documents"
             x:DataType="vm:UserCenterViewModel"
             x:CompileBindings="True"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="CodeWF.AvaloniaControls.DockPrismDemo.Views.Documents.UserCenterView">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="16">
            <Border Padding="24" Background="#1D4ED8" CornerRadius="20">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="{Binding Title}" />
                    <TextBlock Foreground="#DBEAFE"
                               Text="这是一个用于展示身份、权限级别和近期工作区操作的清爽账户页面。" />
                </StackPanel>
            </Border>

            <Border Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <Border Width="88" Height="88" Background="#DBEAFE" CornerRadius="22">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1D4ED8"
                                   Text="OP" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="开源维护者" />
                        <TextBlock Foreground="#475569" Text="负责样例集的发布、问题分拣和工作区质量控制。" />
                        <WrapPanel Margin="0,8,0,0" ItemHeight="36" ItemWidth="130">
                            <Border Padding="10,6" Background="#EFF6FF" CornerRadius="999">
                                <TextBlock Text="管理员" />
                            </Border>
                            <Border Padding="10,6" Background="#F0FDF4" CornerRadius="999">
                                <TextBlock Text="已验证" />
                            </Border>
                            <Border Padding="10,6" Background="#FEF3C7" CornerRadius="999">
                                <TextBlock Text="2 个会话" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

