<UserControl
    x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.SystemSettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:SystemSettingsViewModel"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="4" Spacing="16">
            <Border Padding="22" Background="#111827" CornerRadius="20">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="{Binding Title}" />
                    <TextBlock Foreground="#D1D5DB"
                               Text="将配置分组、安全开关和部署默认值组织为更像真实管理页的结构。" />
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="安全控制" />
                        <CheckBox IsChecked="True" Content="工作区重置前需要确认" />
                        <CheckBox IsChecked="True" Content="保持嵌入工具隔离" />
                        <CheckBox IsChecked="False" Content="允许预览功能模块" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="外壳配置" />
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="运维默认" />
                            <ComboBoxItem Content="诊断模式" />
                            <ComboBoxItem Content="极简模式" />
                        </ComboBox>
                        <TextBlock Foreground="#64748B" Text="该页面演示了无需依赖任何商业 UI 包也能构建专业设置页。" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

