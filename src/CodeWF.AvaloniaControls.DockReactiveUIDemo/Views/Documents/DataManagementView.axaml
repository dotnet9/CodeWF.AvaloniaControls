<UserControl
    x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.DataManagementView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:DataManagementViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Border Padding="22" Background="#0F172A" CornerRadius="20">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="{Binding Title}" />
                    <TextBlock Foreground="#CBD5E1"
                               Text="这里改为更贴近日常运维场景的数据管理工作台，避免普通 Dock 示例再依赖 DataGrid 或 TreeDataGrid。" />
                </StackPanel>
                <Border VerticalAlignment="Top" Padding="12,6" Background="#1D4ED855" CornerRadius="999">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="非表格文档" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="12">
            <Border Padding="16" Background="#F8FBFF" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="13" Foreground="#64748B" Text="待审核计划" />
                    <TextBlock FontSize="28" FontWeight="Bold" Text="12" />
                    <TextBlock Foreground="#475569" Text="包含参数下发、版本发布和批量调度申请。" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="16" Background="#F8FBFF" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="13" Foreground="#64748B" Text="运行资源池" />
                    <TextBlock FontSize="28" FontWeight="Bold" Text="28" />
                    <TextBlock Foreground="#475569" Text="当前在线节点、备用节点与维护窗口中的资源概览。" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="16" Background="#F8FBFF" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="13" Foreground="#64748B" Text="变更任务" />
                    <TextBlock FontSize="28" FontWeight="Bold" Text="5" />
                    <TextBlock Foreground="#475569" Text="今日仍需跟进的灰度发布、回滚演练和配置同步任务。" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.15*,0.85*" ColumnSpacing="16">
            <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="发布编排面板" />
                        <TextBlock Foreground="#64748B" Text="通过任务卡片、阶段清单和执行状态块展示数据管理流程，而不是在普通示例里继续堆表格。" />
                    </StackPanel>

                    <TabControl Grid.Row="1">
                        <TabItem Header="任务队列">
                            <StackPanel Margin="4" Spacing="12">
                                <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="参数模板同步" />
                                            <TextBlock Foreground="#64748B" Text="将 3 套标准工艺参数下发到东区产线，等待班组长确认窗口时间。" />
                                        </StackPanel>
                                        <Border VerticalAlignment="Top" Padding="10,4" Background="#1D4ED822" CornerRadius="999">
                                            <TextBlock Foreground="#1D4ED8" FontWeight="SemiBold" Text="待确认" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="数据归档清理" />
                                            <TextBlock Foreground="#64748B" Text="计划回收 14 天前的批处理缓存，并保留告警快照用于回溯。" />
                                        </StackPanel>
                                        <Border VerticalAlignment="Top" Padding="10,4" Background="#D9770622" CornerRadius="999">
                                            <TextBlock Foreground="#B45309" FontWeight="SemiBold" Text="排队中" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="灰度版本发布" />
                                            <TextBlock Foreground="#64748B" Text="先在 2 个备用节点热切，再推广到主线工作区。" />
                                        </StackPanel>
                                        <Border VerticalAlignment="Top" Padding="10,4" Background="#16653422" CornerRadius="999">
                                            <TextBlock Foreground="#166534" FontWeight="SemiBold" Text="已就绪" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="资源池">
                            <Grid Margin="4" ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Border Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="在线节点" />
                                        <TextBlock Foreground="#64748B" Text="主线 A-01 到 A-12 已全部心跳正常。" />
                                        <TextBlock Foreground="#166534" FontWeight="SemiBold" Text="可用率 100%" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="备用节点" />
                                        <TextBlock Foreground="#64748B" Text="B-03 正在预热，B-07 处于维护窗口，剩余节点随时可接管。" />
                                        <TextBlock Foreground="#B45309" FontWeight="SemiBold" Text="需关注 2 台" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="回滚预案">
                            <Border Margin="4" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                <StackPanel Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="执行顺序" />
                                    <TextBlock Foreground="#64748B" Text="1. 冻结新增任务；2. 切回上一版参数快照；3. 恢复缓存目录；4. 重新开放调度。" />
                                    <TextBlock Foreground="#64748B" Text="该页面用于展示普通文档页完全可以通过卡片、步骤清单和状态块表达业务，而不必都做成表格。" />
                                </StackPanel>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="16">
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="今日值守要点" />
                        <TextBlock Foreground="#64748B" Text="19:30 前完成东区参数模板复核。" />
                        <TextBlock Foreground="#64748B" Text="观察灰度节点 30 分钟内是否出现队列积压。" />
                        <TextBlock Foreground="#64748B" Text="确认夜间清理任务不会影响日志保留周期。" />
                    </StackPanel>
                </Border>
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="审批流" />
                        <TextBlock Foreground="#64748B" Text="运维负责人：已审批" />
                        <TextBlock Foreground="#64748B" Text="工艺负责人：待审批" />
                        <TextBlock Foreground="#64748B" Text="质量追溯：无需审批" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

