<UserControl
    x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.UserCenterView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:UserCenterViewModel"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="4" Spacing="16">
            <Border Padding="22" Background="#1D4ED8" CornerRadius="20">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="{Binding Title}" />
                    <TextBlock Foreground="#DBEAFE"
                               Text="以更干净的产品化结构展示账户身份、职责范围和近期活动。" />
                </StackPanel>
            </Border>

            <Border Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <Border Width="88" Height="88" Background="#DBEAFE" CornerRadius="22">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1D4ED8"
                                   Text="OS" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="开源运维人员" />
                        <TextBlock Foreground="#475569" Text="负责整套示例的工作区质量、样例验证和发布一致性。" />
                        <WrapPanel Margin="0,8,0,0" ItemHeight="36" ItemWidth="140">
                            <Border Padding="10,6" Background="#EFF6FF" CornerRadius="999">
                                <TextBlock Text="维护者" />
                            </Border>
                            <Border Padding="10,6" Background="#F0FDF4" CornerRadius="999">
                                <TextBlock Text="已验证" />
                            </Border>
                            <Border Padding="10,6" Background="#FEF3C7" CornerRadius="999">
                                <TextBlock Text="已启用双重验证" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

