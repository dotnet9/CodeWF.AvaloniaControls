<UserControl
    x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.LogRecordsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:LogRecordsViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Border Padding="22" Background="#111827" CornerRadius="20">
            <StackPanel Spacing="8">
                <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="{Binding Title}" />
                <TextBlock Foreground="#CBD5E1"
                           Text="这里改为时间线与告警摘要组合，避免普通 Dock 示例继续依赖复杂表格控件。" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.15*,0.85*" ColumnSpacing="16">
            <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="操作时间线" />
                        <TextBlock Foreground="#64748B" Text="用日志卡片与阶段标记模拟真实活动记录页，保留文档切换场景，但不再用 DataGrid 承载。" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="12">
                            <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Width="78" Padding="10,6" Background="#1D4ED822" CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center" Foreground="#1D4ED8" FontWeight="SemiBold" Text="10:14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="布局快照已保存" />
                                        <TextBlock Foreground="#64748B" Text="分析页签被拖出主工作区后，系统已自动记录停靠结构并推送到本地快照。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Width="78" Padding="10,6" Background="#16653422" CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center" Foreground="#166534" FontWeight="SemiBold" Text="10:16" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="诊断巡检完成" />
                                        <TextBlock Foreground="#64748B" Text="后台健康检查已完成，本轮未发现阻塞性问题，文档恢复速度保持稳定。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Width="78" Padding="10,6" Background="#D9770622" CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center" Foreground="#B45309" FontWeight="SemiBold" Text="10:19" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="重新打开设置文档" />
                                        <TextBlock Foreground="#64748B" Text="值守人员通过标题栏菜单重新定位到系统设置页，外壳命令链路响应正常。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Padding="14" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Width="78" Padding="10,6" Background="#7C3AED22" CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center" Foreground="#7C3AED" FontWeight="SemiBold" Text="10:23" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="告警路由同步" />
                                        <TextBlock Foreground="#64748B" Text="活动流规则已同步到外部通知通道，后续仅需关注是否出现新的高优先级异常。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="16">
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="事件分类" />
                        <TextBlock Foreground="#64748B" Text="布局类：8" />
                        <TextBlock Foreground="#64748B" Text="运维类：14" />
                        <TextBlock Foreground="#64748B" Text="告警类：3" />
                    </StackPanel>
                </Border>
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="需复核事项" />
                        <TextBlock Foreground="#64748B" Text="检查 10:19 后的设置页缓存是否正确回收。" />
                        <TextBlock Foreground="#64748B" Text="确认日志轮转策略不会打断夜间导出任务。" />
                        <TextBlock Foreground="#64748B" Text="跟踪新一轮通知通道回执是否按时返回。" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
