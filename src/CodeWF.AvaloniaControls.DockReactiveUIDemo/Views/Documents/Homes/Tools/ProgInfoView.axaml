<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents.Homes.Tools"
             xmlns:models="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.Models.Documents.Homes.Tools"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="vm:ProgInfoViewModel"
             x:CompileBindings="True"
             x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.Homes.Tools.ProgInfoView">
    <Border Padding="14" Background="White" CornerRadius="16">
        <StackPanel Spacing="12">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Foreground="#64748B"
                       Text="多级树结构用于演示在紧凑工具面板中浏览嵌套进程、节点或流水线信息的效果。" />
            <Border Padding="10" Background="#F8FAFC" CornerRadius="12">
                <TreeView ItemsSource="{Binding MultipleLevelItems}">
                    <TreeView.DataTemplates>
                        <TreeDataTemplate DataType="models:FirstItem" ItemsSource="{Binding SecondItems}">
                            <TextBlock Text="{Binding Name}" />
                        </TreeDataTemplate>
                        <TreeDataTemplate DataType="models:SecondItem" ItemsSource="{Binding ThirdItemItems}">
                            <TextBlock Text="{Binding Name}" />
                        </TreeDataTemplate>
                        <TreeDataTemplate DataType="models:ThirdItem">
                            <TextBlock Text="{Binding Name}" />
                        </TreeDataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
