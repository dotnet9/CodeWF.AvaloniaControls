<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents.Homes.Tools"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="vm:LogViewModel"
             x:CompileBindings="True"
             x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.Homes.Tools.LogView">
    <Border Padding="14" Background="White" CornerRadius="16">
        <StackPanel Spacing="12">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title}" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <TextBlock FontWeight="SemiBold" Text="10:14" />
                <TextBlock Grid.Column="1" Text="分析页签被拖出后，工作区快照已保存。" />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <TextBlock FontWeight="SemiBold" Text="10:16" />
                <TextBlock Grid.Column="1" Text="后台诊断已完成，未发现阻塞性问题。" />
            </Grid>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <TextBlock FontWeight="SemiBold" Text="10:19" />
                <TextBlock Grid.Column="1" Text="运维人员已通过标题栏菜单重新打开设置文档。" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

