<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CodeWF.AvaloniaControls.DockReactiveUIDemo.ViewModels.Documents.Homes.Tools"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="vm:SysInfoViewModel"
             x:CompileBindings="True"
             x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.Views.Documents.Homes.Tools.SysInfoView">
    <Border Padding="14" Background="White" CornerRadius="16">
        <StackPanel Spacing="12">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title}" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                <TextBlock Text="运行时" />
                <TextBlock Grid.Column="1" Text=".NET 11 预览版" />
                <TextBlock Grid.Row="1" Text="UI 框架" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Avalonia 12.0.2" />
                <TextBlock Grid.Row="2" Text="主题链路" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Ursa + 免费 Semi 主题链路" />
                <TextBlock Grid.Row="3" Text="打包" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="已提供一键 bat 打包脚本" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>


