<Application
    x:Class="CodeWF.AvaloniaControls.DockReactiveUIDemo.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
    xmlns:local="clr-namespace:CodeWF.AvaloniaControls.DockReactiveUIDemo"
    xmlns:uSemi="https://irihi.tech/ursa/themes/semi"
    xmlns:semi="https://irihi.tech/semi">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <ControlRecycling x:Key="ControlRecyclingKey" TryToUseIdAsKey="True" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <fluent:FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <uSemi:SemiTheme Locale="zh-CN" />
        <semi:DockSemiTheme />
        <codewf:DockCodeWFTheme />
        <StyleInclude Source="Index.axaml" />
        <!-- 无障碍滚动条：默认常显且加宽，方便老年用户识别和拖动。 -->
        <Style Selector="ScrollViewer">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>
        <Style Selector="DockControl">
            <Setter Property="(ControlRecyclingDataTemplate.ControlRecycling)" 
                    Value="{StaticResource ControlRecyclingKey}" />
        </Style>
    </Application.Styles>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/logo.ico" Clicked="OpenMainWindow_Clicked" >
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="测试应用" />
                        <NativeMenuItem Header="显示主窗口" Click="OpenMainWindow_Clicked" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="退出" Click="Exit_Clicked" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>

