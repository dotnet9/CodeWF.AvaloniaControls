<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
	<PropertyGroup>
		<Configuration>Release</Configuration>
		<!-- 平台编译符号 -->
		<DefineConstants>LINUX64</DefineConstants>
		<!-- AOT核心配置：在Windows上无法跨平台AOT编译，暂时禁用 -->
		<PublishAot>false</PublishAot>
		<!-- Linux主流架构：x64（amd64）是最通用的，也可改为linux-arm64适配ARM架构 -->
		<Platform>Any CPU</Platform>
		<PublishDir>..\..\publish\dotnet11\linux-x64</PublishDir>
		<PublishProtocol>FileSystem</PublishProtocol>
		<_TargetId>Folder</_TargetId>
		<!-- Linux无需windows后缀 -->
		<TargetFramework>net11.0</TargetFramework>
		<!-- Linux运行时标识 -->
		<RuntimeIdentifier>linux-x64</RuntimeIdentifier>
		<SelfContained>true</SelfContained>
		<!-- 单文件发布优化（Linux下同样生效） -->
		<PublishSingleFile>true</PublishSingleFile>
		<!-- 启用单文件压缩，减小体积 -->
		<CompressSingleFile>true</CompressSingleFile>
		<!-- AOT模式下必须关闭R2R，避免冲突和体积膨胀 -->
		<!-- 裁剪优化 -->
		<PublishTrimmed>true</PublishTrimmed>
		<!-- 体积精简：移除调试符号和冗余资源 -->
		<DebugType>none</DebugType>
		<DebugSymbols>false</DebugSymbols>
		<SatelliteResourceLanguages>zh-CN;en</SatelliteResourceLanguages>
		<!-- 仅保留中英双语资源 -->
		<CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
		<!-- AOT安全与兼容优化 -->
		<!-- 关闭不安全序列化 -->
		<EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
		<!-- 抑制无关裁剪警告 -->
		<SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
		<!-- Linux特有优化：禁用Windows相关依赖，减小体积 -->
		<UseWindowsForms>false</UseWindowsForms>
		<UseWpf>false</UseWpf>
		<DisableWindowsSpecificDependencies>true</DisableWindowsSpecificDependencies>
	</PropertyGroup>
</Project>