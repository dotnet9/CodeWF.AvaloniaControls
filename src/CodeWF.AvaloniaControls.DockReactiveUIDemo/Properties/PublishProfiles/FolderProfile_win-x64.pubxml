<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <!-- 平台编译符号 -->
    <DefineConstants>WIN64</DefineConstants>
    <!-- AOT核心配置：启用AOT编译 -->
    <PublishAot>true</PublishAot>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\publish\dotnet11\win-x64</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net11.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- 单文件发布优化 -->
    <PublishSingleFile>true</PublishSingleFile>
    <!-- 启用单文件压缩，减小体积 -->
    <CompressSingleFile>true</CompressSingleFile>
    <!-- AOT模式下必须关闭R2R，避免冲突和体积膨胀 -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <!-- 裁剪优化 -->
    <!-- 体积精简：移除调试符号和冗余资源 -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <SatelliteResourceLanguages>zh-CN;en</SatelliteResourceLanguages>
    <!-- 仅保留中英双语资源 -->
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <!-- AOT安全与兼容优化 -->
    <!-- 关闭不安全序列化 -->
    <EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
    <!-- 抑制无关裁剪警告 -->
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
  </PropertyGroup>
</Project>