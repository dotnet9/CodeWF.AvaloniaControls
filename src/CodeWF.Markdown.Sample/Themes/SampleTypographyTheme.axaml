<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="https://codewf.com">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SampleInkGreenAccentBrush" Color="#0F766E" />
                    <SolidColorBrush x:Key="SampleInkGreenSoftBrush" Color="#ECFDF5" />
                    <SolidColorBrush x:Key="SampleInkGreenHeaderBrush" Color="#CCFBF1" />
                    <SolidColorBrush x:Key="SampleInkGreenCodeBrush" Color="#F1F5F9" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SampleInkGreenAccentBrush" Color="#5EEAD4" />
                    <SolidColorBrush x:Key="SampleInkGreenSoftBrush" Color="#12312D" />
                    <SolidColorBrush x:Key="SampleInkGreenHeaderBrush" Color="#17413B" />
                    <SolidColorBrush x:Key="SampleInkGreenCodeBrush" Color="#0B1719" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- 示例追加排版主题：Key 为 SampleInkGreen 时，MarkdownViewer 会拥有 MdThemeSampleInkGreen 样式类。 -->
    <Style Selector="md|MarkdownViewer.MdThemeSampleInkGreen">
        <Setter Property="AccentBrush" Value="{DynamicResource SampleInkGreenAccentBrush}" />
        <Setter Property="QuoteBackgroundBrush" Value="{DynamicResource SampleInkGreenSoftBrush}" />
        <Setter Property="InlineCodeBackgroundBrush" Value="{DynamicResource SampleInkGreenSoftBrush}" />
        <Setter Property="TableHeaderBackgroundBrush" Value="{DynamicResource SampleInkGreenHeaderBrush}" />
        <Setter Property="CodeBackgroundBrush" Value="{DynamicResource SampleInkGreenCodeBrush}" />
        <Setter Property="ParagraphFontSize" Value="17" />
        <Setter Property="ParagraphLineHeight" Value="31" />
        <Setter Property="Heading1FontSize" Value="34" />
        <Setter Property="Heading2FontSize" Value="28" />
    </Style>
</Styles>
