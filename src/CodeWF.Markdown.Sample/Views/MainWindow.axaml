<Window
    x:Class="CodeWF.Markdown.Sample.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="https://codewf.com"
    xmlns:vm="using:CodeWF.Markdown.Sample.ViewModels"
    Title="CodeWF.Markdown 示例"
    Width="1280"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/logo.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0 0 6 0" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="ComboBox.toolbar-combo">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Margin" Value="0 0 16 0" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border
            Padding="14 12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                <TextBlock Classes="label" Text="黑白主题" />
                <ComboBox
                    Grid.Column="1"
                    Classes="toolbar-combo"
                    DisplayMemberBinding="{Binding Name}"
                    ItemsSource="{Binding ThemeVariants}"
                    SelectedItem="{Binding SelectedThemeVariant}" />

                <TextBlock Grid.Column="2" Classes="label" Text="排版主题" />
                <ComboBox
                    Grid.Column="3"
                    HorizontalAlignment="Left"
                    MinWidth="190"
                    DisplayMemberBinding="{Binding Name}"
                    ItemsSource="{Binding TypographyThemes}"
                    SelectedItem="{Binding SelectedTypographyTheme}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="460,*">
            <Border
                Padding="14"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0 0 1 0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Markdown 输入" />
                    <ComboBox
                        Grid.Row="1"
                        Margin="0 10 0 12"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{Binding MarkdownFiles}"
                        SelectedItem="{Binding SelectedFile}" />
                    <TextBox
                        Grid.Row="2"
                        AcceptsReturn="True"
                        FontFamily="Consolas, Cascadia Mono"
                        FontSize="13"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Text="{Binding Markdown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" Padding="34 28">
                <md:MarkdownViewer
                    BasePath="{Binding MarkdownBasePath}"
                    Markdown="{Binding Markdown}"
                    TypographyTheme="{Binding SelectedTypographyThemeKey}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
