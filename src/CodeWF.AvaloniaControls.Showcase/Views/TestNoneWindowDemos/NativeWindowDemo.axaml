<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        Width="460"
        Height="320"
        x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.NativeWindowDemo"
        Title="原生窗口">
    <Border Background="#F8FAFC" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="14" Padding="24">
        <StackPanel Spacing="8" VerticalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="Bold" Text="原生窗口" />
            <TextBlock Foreground="#64748B"
                       Text="这是默认的平台窗口，用作对比 Ursa 自定义外壳方案前的基线参考。" />
        </StackPanel>
    </Border>
</Window>
