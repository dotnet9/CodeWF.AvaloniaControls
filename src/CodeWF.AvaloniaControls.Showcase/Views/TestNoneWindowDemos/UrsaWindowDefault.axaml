<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:i18n="https://codewf.com"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:windowLangs="clr-namespace:Showcase.Windows"
              mc:Ignorable="d"
              d:DesignWidth="800"
              d:DesignHeight="450"
              Width="460"
              Height="320"
              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
              WindowStartupLocation="CenterScreen"
              x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.UrsaWindowDefault"
              Title="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultTitle}}">
    <u:UrsaWindow.Resources>
        <Color x:Key="CaptionButtonForeground">#0F172A</Color>
    </u:UrsaWindow.Resources>
    <Border Background="{DynamicResource ShowcaseSubtleBackground}" BorderBrush="{DynamicResource ShowcaseBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel Spacing="8" VerticalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultHeading}}" />
            <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                       Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDefaultDescription}}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</u:UrsaWindow>
