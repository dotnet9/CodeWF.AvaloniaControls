<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:i18n="https://codewf.com"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:windowLangs="clr-namespace:Showcase.Windows"
              mc:Ignorable="d"
              d:DesignWidth="520"
              d:DesignHeight="320"
              Width="520"
              Height="320"
              Background="{DynamicResource ShowcaseCardBackground}"
              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
              WindowDecorations="None"
              WindowStartupLocation="CenterScreen"
              x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.UrsaWindowWithNone"
              Title="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaNoneTitle}}">
    <Border Background="{DynamicResource ShowcaseCardBackground}"
            BorderBrush="{DynamicResource ShowcaseBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="4">
        <Grid RowDefinitions="58,*">
            <Border Background="{DynamicResource ShowcaseSubtleBackground}"
                    BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    PointerPressed="TitleBar_OnPointerPressed">
                <Grid Margin="18,0,12,0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Background="{DynamicResource ShowcaseAccentSubtleBrush}"
                            CornerRadius="7">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ShowcaseAccentTextBrush}"
                                   Text="U" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShowcaseTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaNoneHeading}}" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaNoneTitle}}" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Classes="WindowCaptionButton WindowCloseButton"
                            Click="Close_OnClick"
                            ToolTip.Tip="{i18n:I18n {x:Static windowLangs:WindowDemos.Close}}">
                        <Path Width="12"
                              Height="12"
                              Data="M 1 1 L 11 11 M 11 1 L 1 11"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeLineCap="Round"
                              StrokeThickness="1.6"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26,24" RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaNoneHeading}}" />
                <TextBlock Grid.Row="1"
                           Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaNoneDescription}}"
                           TextWrapping="Wrap" />
            </Grid>
        </Grid>
    </Border>
</u:UrsaWindow>
