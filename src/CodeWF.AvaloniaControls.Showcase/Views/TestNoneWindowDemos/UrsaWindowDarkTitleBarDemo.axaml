<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:i18n="https://codewf.com"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:windowLangs="clr-namespace:Showcase.Windows"
              mc:Ignorable="d"
              d:DesignWidth="560"
              d:DesignHeight="360"
              Width="560"
              Height="360"
              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
              Icon="/Assets/logo.ico"
              WindowStartupLocation="CenterScreen"
              x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.UrsaWindowDarkTitleBarDemo"
              Title="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDarkTitle}}">
    <u:UrsaWindow.Resources>
        <Color x:Key="CaptionButtonForeground">#FFFFFF</Color>
    </u:UrsaWindow.Resources>

    <u:UrsaWindow.LeftContent>
        <Grid Height="42"
              Margin="6,0"
              ColumnDefinitions="Auto,Auto"
              ColumnSpacing="10"
              IsHitTestVisible="False">
            <Border Width="28"
                    Height="28"
                    VerticalAlignment="Center"
                    Background="#2563EB"
                    CornerRadius="7">
                <Image Width="18"
                       Height="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality"
                       Source="/Assets/logo.png" />
            </Border>
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="1">
                <TextBlock FontWeight="SemiBold"
                           Foreground="White"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDarkHeading}}" />
                <TextBlock FontSize="11"
                           Foreground="#CBD5E1"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.TitleBarSlotsLabel}}" />
            </StackPanel>
        </Grid>
    </u:UrsaWindow.LeftContent>

    <u:UrsaWindow.RightContent>
        <StackPanel Margin="0,0,8,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    IsHitTestVisible="False">
            <Border Padding="10,4"
                    VerticalAlignment="Center"
                    Background="#22C55E22"
                    BorderBrush="#22C55E66"
                    BorderThickness="1"
                    CornerRadius="999">
                <TextBlock FontSize="12"
                           Foreground="#BBF7D0"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.Online}}" />
            </Border>
        </StackPanel>
    </u:UrsaWindow.RightContent>

    <Border Background="#0F172A">
        <Grid Margin="18"
              RowDefinitions="Auto,*"
              RowSpacing="14">
            <StackPanel Spacing="6">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDarkHeading}}" />
                <TextBlock Foreground="#CBD5E1"
                           TextWrapping="Wrap"
                           Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaDarkDescription}}" />
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Padding="16"
                        Background="#111827"
                        BorderBrush="#243041"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.TitleBarContent}}" />
                        <TextBlock Foreground="#94A3B8"
                                   TextWrapping="Wrap"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.TitleBarContentDesc}}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Padding="16"
                        Background="#111827"
                        BorderBrush="#243041"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.Scenario}}" />
                        <TextBlock Foreground="#94A3B8"
                                   TextWrapping="Wrap"
                                   Text="{i18n:I18n {x:Static windowLangs:WindowDemos.ScenarioDesc}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</u:UrsaWindow>
