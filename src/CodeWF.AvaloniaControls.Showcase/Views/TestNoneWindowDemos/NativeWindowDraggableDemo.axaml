<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i18n="https://codewf.com"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windowLangs="clr-namespace:Showcase.Windows"
        mc:Ignorable="d"
        d:DesignWidth="560"
        d:DesignHeight="340"
        Width="560"
        Height="340"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        TransparencyBackgroundFallback="Transparent"
        TransparencyLevelHint="Transparent"
        WindowDecorations="None"
        WindowStartupLocation="CenterScreen"
        x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.NativeWindowDraggableDemo"
        Title="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeMoveTitle}}">
    <Border Background="#1E293B"
            ClipToBounds="True"
            CornerRadius="4">
        <Border Margin="1"
                Background="{DynamicResource ShowcaseCardBackground}"
                ClipToBounds="True"
                CornerRadius="3">
            <Grid RowDefinitions="64,*">
                <Border Background="#0F172A"
                        PointerPressed="TitleBar_OnPointerPressed">
                    <Grid Margin="20,0,12,0"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Border Width="32"
                                Height="32"
                                VerticalAlignment="Center"
                                Background="#2563EB"
                                CornerRadius="8">
                            <Image Width="20"
                                   Height="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   Source="/Assets/logo.png" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeMoveHeading}}" />
                            <TextBlock FontSize="12"
                                       Foreground="#CBD5E1"
                                       Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeMoveTitle}}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="WindowCaptionButton WindowCloseButton"
                                Foreground="#E2E8F0"
                                Click="Close_OnClick">
                            <Path Width="12"
                                  Height="12"
                                  Data="M 1 1 L 11 11 M 11 1 L 1 11"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeLineCap="Round"
                                  StrokeThickness="1.6"
                                  Stretch="Uniform" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="28,26"
                      RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseTextBrush}"
                               Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeMoveHeading}}" />
                    <TextBlock Grid.Row="1"
                               Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                               Text="{i18n:I18n {x:Static windowLangs:WindowDemos.NativeMoveDescription}}"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
