<u:UrsaWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:i18n="https://codewf.com"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:windowLangs="clr-namespace:Showcase.Windows"
              mc:Ignorable="d"
              d:DesignWidth="520"
              d:DesignHeight="300"
              Width="520"
              Height="300"
              Background="{DynamicResource ShowcaseCardBackground}"
              CanResize="False"
              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
              Icon="/Assets/logo.ico"
              WindowDecorations="None"
              WindowStartupLocation="CenterScreen"
              x:Class="CodeWF.AvaloniaControls.Showcase.Views.TestNoneWindowDemos.UrsaWindowCompactToolDemo"
              Title="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaCompactTitle}}">
    <Border Background="{DynamicResource ShowcaseCardBackground}"
            BorderBrush="{DynamicResource ShowcaseBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="4">
        <Grid RowDefinitions="44,*">
            <Border Background="{DynamicResource ShowcaseSubtleBackground}"
                    BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    PointerPressed="TitleBar_OnPointerPressed">
                <Grid Margin="14,0,8,0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="9">
                    <Border Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            Background="#E0F2FE"
                            CornerRadius="6">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#0369A1"
                                   Text="T" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseTextBrush}"
                               Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaCompactHeading}}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Classes="WindowCaptionButton" Click="Minimize_OnClick">
                            <Border Width="12"
                                    Height="1.6"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    CornerRadius="1" />
                        </Button>
                        <Button Classes="WindowCaptionButton WindowCloseButton" Click="Close_OnClick">
                            <Path Width="12"
                                  Height="12"
                                  Data="M 1 1 L 11 11 M 11 1 L 1 11"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeLineCap="Round"
                                  StrokeThickness="1.6"
                                  Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="22"
                  RowDefinitions="Auto,*"
                  RowSpacing="14">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShowcaseTextBrush}"
                               Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaCompactHeading}}" />
                    <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{i18n:I18n {x:Static windowLangs:WindowDemos.UrsaCompactDescription}}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Padding="14"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static windowLangs:WindowDemos.FixedSize}}" />
                            <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="{i18n:I18n {x:Static windowLangs:WindowDemos.FixedSizeDesc}}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="14"
                            Background="{DynamicResource ShowcaseSubtleBackground}"
                            BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ShowcaseTextBrush}" Text="{i18n:I18n {x:Static windowLangs:WindowDemos.LightTitleBar}}" />
                            <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}" Text="{i18n:I18n {x:Static windowLangs:WindowDemos.LightTitleBarDesc}}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</u:UrsaWindow>
