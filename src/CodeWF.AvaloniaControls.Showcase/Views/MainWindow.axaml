<u:UrsaWindow
    x:Class="CodeWF.AvaloniaControls.Showcase.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:CodeWF.AvaloniaControls.Showcase.Pages"
    xmlns:u="https://irihi.tech/ursa"
    Title="CodeWF 控件示例"
    Width="1280"
    Height="860"
    Background="#F3F6FB"
    ExtendClientAreaTitleBarHeightHint="56"
    FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
    WindowStartupLocation="CenterScreen"
    d:DesignHeight="860"
    d:DesignWidth="1280"
    Icon="/Assets/logo.ico"
    mc:Ignorable="d">
    <u:UrsaWindow.Resources>
        <Color x:Key="CaptionButtonForeground">#0F172A</Color>
        <SolidColorBrush x:Key="CaptionButtonBackgroundPointerOver">#EEF2F7</SolidColorBrush>
        <SolidColorBrush x:Key="CaptionButtonBackgroundPressed">#E2E8F0</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBorderBrush">#DCE3EE</SolidColorBrush>
    </u:UrsaWindow.Resources>

    <u:UrsaWindow.Styles>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style Selector="u|TitleBar">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE3EE" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinWidth" Value="154" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </u:UrsaWindow.Styles>

    <u:UrsaWindow.LeftContent>
        <Grid Height="56"
              Margin="14,0,12,0"
              ColumnDefinitions="Auto,Auto"
              ColumnSpacing="12"
              IsHitTestVisible="False">
            <Border Width="34"
                    Height="34"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#DCE3EE"
                    BorderThickness="1"
                    CornerRadius="9">
                <Image Width="22"
                       Height="22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality"
                       Source="/Assets/logo.png" />
            </Border>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="#0F172A"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Text="CodeWF 控件示例" />
        </Grid>
    </u:UrsaWindow.LeftContent>

    <Border Background="#F3F6FB">
        <Border Margin="18,74,18,18" Classes="Panel" Padding="12">
            <TabControl Background="Transparent"
                        Classes.ReverseSeparator="False"
                        TabStripPlacement="Left"
                        Theme="{StaticResource LineTabControl}">
                <TabItem Header="说明">
                    <pages:OverviewDemo />
                </TabItem>
                <TabItem Header="穿梭框">
                    <pages:TransferDemo />
                </TabItem>
                <TabItem Header="VComboBox">
                    <pages:VComboBoxDemo />
                </TabItem>
                <TabItem Header="TabControl">
                    <pages:TabControlDemo />
                </TabItem>
                <TabItem Header="StatusBadge">
                    <pages:StatusBadgeDemo />
                </TabItem>
                <TabItem Header="状态卡片">
                    <pages:StatusCardDemo />
                </TabItem>
                <TabItem Header="Markup">
                    <pages:MarkupExtensionsDemo />
                </TabItem>
                <TabItem Header="AnimatedImage">
                    <pages:AnimatedImageDemo />
                </TabItem>
                <TabItem Header="Ursa 窗口">
                    <pages:TestNoneWindowDemo />
                </TabItem>
            </TabControl>
        </Border>
    </Border>
</u:UrsaWindow>
