<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:codewf="https://codewf.com"
             mc:Ignorable="d"
             d:DesignWidth="920"
             d:DesignHeight="520"
             x:Class="CodeWF.AvaloniaControls.Showcase.Pages.StatusLabelDemo">
    <UserControl.Styles>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="#F8FAFC"
                BorderBrush="#E4E9F2"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="状态标签" />
                <TextBlock Classes="Caption"
                           Text="它是状态卡片的轻量替代方案，适合列表、工具栏和紧凑概览面板中的行内状态展示。" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="14">
            <WrapPanel ItemWidth="240" Orientation="Horizontal">
                <codewf:StatusLabel Width="220"
                                    LeftText="网关"
                                    RightText="调试"
                                     Kind="{x:Static codewf:StatusLabelKind.Debug}" />
                <codewf:StatusLabel Width="220"
                                    LeftText="采集器"
                                    RightText="信息"
                                     Kind="{x:Static codewf:StatusLabelKind.Info}"
                                    FontSize="16"
                                    CornerRadius="4"
                                    Padding="6 2" />
                <codewf:StatusLabel Width="220"
                                    LeftText="存储"
                                    RightText="警告"
                                     Kind="{x:Static codewf:StatusLabelKind.Warn}"
                                    FontSize="24"
                                    CornerRadius="8"
                                    Padding="10 4" />
                <codewf:StatusLabel Width="220"
                                    LeftText="计算节点"
                                    RightText="错误"
                                     Kind="{x:Static codewf:StatusLabelKind.Error}"
                                    FontSize="32"
                                    CornerRadius="18"
                                    Padding="15 4" />
                <codewf:StatusLabel Width="220"
                                    LeftText="数据库"
                                    RightText="严重"
                                     Kind="{x:Static codewf:StatusLabelKind.Fatal}"
                                    FontSize="32"
                                    CornerRadius="18"
                                    Padding="15 4" />
            </WrapPanel>

            <Border Grid.Column="1"
                    Padding="18"
                    Background="#FFFFFF"
                    BorderBrush="#E4E9F2"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="标签的价值" />
                    <TextBlock Classes="Caption" Text="标签非常适合紧凑、高密度的界面区域。" />
                    <TextBlock Classes="Caption" Text="它能在不占用过多横向空间的前提下保持服务状态可读。" />
                    <TextBlock Classes="Caption" Text="放大后的样式也适合作为关键运行状态的醒目标识。" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

