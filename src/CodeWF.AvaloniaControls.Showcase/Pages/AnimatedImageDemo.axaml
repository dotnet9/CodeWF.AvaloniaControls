<UserControl
    x:Class="CodeWF.AvaloniaControls.Showcase.Pages.AnimatedImageDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:anim="https://github.com/whistyun/AnimatedImage.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="560"
    d:DesignWidth="980"
    mc:Ignorable="d">
    <UserControl.Styles>
        <Style Selector="Border.PreviewPanel">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE3EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style Selector="TextBlock.Title">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.Source">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Image.AnimatedPreview">
            <Setter Property="Width" Value="450" />
            <Setter Property="Height" Value="200" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="18">
            <StackPanel Spacing="8">
                <TextBlock FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Text="AnimatedImage 动态 GIF" />
                <TextBlock Foreground="#64748B"
                           Text="同一个 nice.gif 资源分别通过 Avalonia 资源 URI 和网络 URI 加载。" />
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="18"
                  RowDefinitions="*">
                <Border Classes="PreviewPanel">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                        <TextBlock Classes="Title" Text="本地资源" />
                        <TextBlock Grid.Row="1" Classes="Source"
                                   Text="avares://CodeWF.AvaloniaControls.Showcase/Assets/nice.gif" />
                        <Border Grid.Row="2"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Image Classes="AnimatedPreview"
                                   anim:ImageBehavior.AnimatedSource="avares://CodeWF.AvaloniaControls.Showcase/Assets/nice.gif"
                                   anim:ImageBehavior.RepeatBehavior="Forever" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="PreviewPanel">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                        <TextBlock Classes="Title" Text="网络资源" />
                        <TextBlock Grid.Row="1" Classes="Source"
                                   Text="https://img1.dotnet9.com/2026/05/nice.gif" />
                        <Border Grid.Row="2"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Image Classes="AnimatedPreview"
                                   anim:ImageBehavior.AnimatedSource="https://img1.dotnet9.com/2026/05/nice.gif"
                                   anim:ImageBehavior.RepeatBehavior="Forever" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
