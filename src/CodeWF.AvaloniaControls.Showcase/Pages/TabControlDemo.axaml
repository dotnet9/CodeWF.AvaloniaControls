<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i18n="https://codewf.com"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pageLangs="clr-namespace:Showcase.Pages"
             mc:Ignorable="d"
             d:DesignWidth="920"
             d:DesignHeight="520"
             x:Class="CodeWF.AvaloniaControls.Showcase.Pages.TabControlDemo">
    <Grid RowDefinitions="Auto,*,*" RowSpacing="14">
        <Border Padding="16"
                Background="{DynamicResource ShowcaseSubtleBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel Spacing="6">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Title}}" />
                <TextBlock Foreground="{DynamicResource ShowcaseMutedTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.Description}}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="18"
                Background="{DynamicResource ShowcaseCardBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BusinessStyle}}" />
                <TabControl Grid.Row="1"
                            VerticalAlignment="Top"
                            Theme="{StaticResource TrapezoidShapedTabControl}"
                            CornerRadius="10 10 0 0"
                            TabStripPlacement="Top">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="CornerRadius" Value="10 10 0 0" />
                            <Setter Property="Padding" Value="12 8" />
                        </Style>
                    </TabControl.Styles>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.DataManagement}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.SystemSettings}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.UserCenter}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.LogRecords}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.HelpDocs}}" />
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="18"
                Background="{DynamicResource ShowcaseCardBackground}"
                BorderBrush="{DynamicResource ShowcaseSubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource ShowcaseTextBrush}"
                           Text="{i18n:I18n {x:Static pageLangs:TabControlDemo.BrandStyle}}" />
                <TabControl Grid.Row="1"
                            VerticalAlignment="Top"
                            Theme="{StaticResource TrapezoidShapedTabControl}"
                            CornerRadius="10 10 0 0"
                            TabStripPlacement="Top">
                    <TabControl.Styles>
                        <Style Selector="TabControl">
                            <Setter Property="Background" Value="#551890FF" />
                        </Style>
                        <Style Selector="TabItem">
                            <Setter Property="CornerRadius" Value="10 10 0 0" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="Padding" Value="12 8" />
                            <Setter Property="MinHeight" Value="40" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStops>
                                            <GradientStop Color="#BAE7FF" Offset="0" />
                                            <GradientStop Color="#FFFFFF" Offset="1" />
                                        </GradientStops>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Styles>
                    <TabControl.Resources>
                        <SolidColorBrush x:Key="TabItemLineHeaderPointeroverForeground">#1890FF</SolidColorBrush>
                        <SolidColorBrush x:Key="TabItemLineHeaderSelectedForeground">#1890FF</SolidColorBrush>
                    </TabControl.Resources>
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.DataManagement}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.SystemSettings}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.UserCenter}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.LogRecords}}" />
                    <TabItem Header="{i18n:I18n {x:Static pageLangs:TabControlDemo.HelpDocs}}" />
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>

