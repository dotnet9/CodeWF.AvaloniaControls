<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CodeWF.AvaloniaControls.Showcase.App"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:uSemi="https://irihi.tech/ursa/themes/semi"
             xmlns:codewf="https://codewf.com">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="Styles/Brushes.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <fluent:FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <semi:AvaloniaEditSemiTheme />
        <uSemi:SemiTheme Locale="zh-CN" />
		<codewf:CodeWFTheme />
        <!-- 无障碍滚动条：默认常显且加宽，方便老年用户识别和拖动。 -->
        <Style Selector="ScrollViewer">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>
    </Application.Styles>
</Application>
