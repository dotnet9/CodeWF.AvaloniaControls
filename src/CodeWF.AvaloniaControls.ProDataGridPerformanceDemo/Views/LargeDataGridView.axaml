<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="CodeWF.AvaloniaControls.ProDataGridPerformanceDemo.Views.LargeDataGridView">
    <Grid RowDefinitions="Auto,*" RowSpacing="14">
        <Border Padding="16"
                Background="#F8FAFC"
                BorderBrush="#E4E9F2"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel Spacing="6">
                <TextBlock x:Name="HeaderTitleBlock" FontSize="20" FontWeight="SemiBold" />
                <TextBlock x:Name="HeaderDescriptionBlock" Foreground="#5B6472" />
                <TextBlock x:Name="SummaryBlock" Foreground="#334155" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E4E9F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="0">
            <DataGrid x:Name="ProcessDataGrid" />
        </Border>
    </Grid>
</UserControl>
