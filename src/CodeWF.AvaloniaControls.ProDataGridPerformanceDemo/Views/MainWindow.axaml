<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodeWF.AvaloniaControls.ProDataGridPerformanceDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:CodeWF.AvaloniaControls.ProDataGridPerformanceDemo.Views"
        x:Class="CodeWF.AvaloniaControls.ProDataGridPerformanceDemo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1380"
        Height="900"
        Background="#F4F7FB"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        Icon="/Assets/avalonia-logo.ico"
        Title="ProDataGrid 性能回归示例"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        d:DesignWidth="1380"
        d:DesignHeight="900">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E4E9F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="#5B6472" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid Margin="22" RowDefinitions="Auto,*" RowSpacing="18">
        <Border Classes="Panel"
                Padding="28"
                Background="#0F172A">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="ProDataGrid 大数据页签切换回归示例" />
                    <TextBlock Classes="Caption"
                               MaxWidth="860"
                               Foreground="#CBD5E1"
                               Text="这个样例专门围绕“表格数据量很大、Tab 页和文档页频繁切换”的真实场景构建，用来验证 Avalonia 12 主线下的开源高性能表格方案是否足够流畅。" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Top">
                    <Border Padding="12,6" Background="#1D4ED855" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Avalonia 12" />
                    </Border>
                    <Border Padding="12,6" Background="#0F766E55" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="MIT 开源 ProDataGrid" />
                    </Border>
                    <Border Padding="12,6" Background="#9A341255" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="大数据量切换" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="2"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                    <Border Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="基础交互" />
                            <TextBlock Foreground="#64748B" Text="先用 12,000 行基础样例验证列宽、排序和滚动行为。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="大页签切换" />
                            <TextBlock Foreground="#64748B" Text="使用十万级数据量模拟多个常驻页签来回切换。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="文档工作区" />
                            <TextBlock Foreground="#64748B" Text="模拟 Dock Document 类似的多文档切换压力场景。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="Panel" Padding="14">
            <TabControl>
                <TabItem Header="基础交互">
                    <views:DataGridDemo />
                </TabItem>
                <TabItem Header="十万行页签">
                    <views:LargeDataGridView HeaderTitle="十万行切换页签"
                                             HeaderDescription="120,000 行常驻数据，重点观察页签来回切换时是否依然顺畅。"
                                             RowCount="120000"
                                             Seed="23" />
                </TabItem>
                <TabItem Header="二十万行页签">
                    <views:LargeDataGridView HeaderTitle="二十万行切换页签"
                                             HeaderDescription="180,000 行更高压力场景，用来放大滚动和重绘上的潜在卡顿。"
                                             RowCount="180000"
                                             Seed="29" />
                </TabItem>
                <TabItem Header="文档工作区">
                    <views:DocumentWorkspaceView />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
