<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodeWF.AvaloniaControls.FluentStarterDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1120"
        d:DesignHeight="760"
        x:Class="CodeWF.AvaloniaControls.FluentStarterDemo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Background="#F4F7FB"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        Title="Fluent 起步页示例"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE3EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style Selector="Button.Action">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="16,10" />
        </Style>
    </Window.Styles>

    <Grid Margin="22" RowDefinitions="Auto,*" RowSpacing="18">
        <Border Classes="Panel"
                Padding="28"
                Background="#0F172A">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="Fluent 起步页示例" />
                    <TextBlock MaxWidth="760"
                               Foreground="#CBD5E1"
                               Text="{Binding Greeting}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                    <Border Padding="12,6" Background="#1D4ED855" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="Fluent" />
                    </Border>
                    <Border Padding="12,6" Background="#0F766E55" CornerRadius="999">
                        <TextBlock Foreground="White" FontWeight="SemiBold" Text="起步示例" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="视觉基线" />
                            <TextBlock Foreground="#64748B" Text="使用简洁布局验证 Fluent 主题的层级、间距和控件细节表现。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="表单模式" />
                            <TextBlock Foreground="#64748B" Text="包含适合作为桌面应用起步页的标准输入与操作模式。" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="16" Background="#F8FBFF" CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="卡片布局" />
                            <TextBlock Foreground="#64748B" Text="结合紧凑信息卡片与清晰操作区，使展示更完整。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
            <Border Classes="Panel" Padding="24">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="24" FontWeight="Bold" Text="Fluent 桌面起步页" />
                        <TextBlock Classes="Caption" Text="一个包含引导区、输入区、操作区和摘要卡片的轻量起步页面。" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             PlaceholderText="输入一段简短说明，例如：初始化一个新的桌面工具项目" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
                        <Button Classes="Action" Content="创建工作区" />
                        <Button Classes="Action" Content="导入配置" />
                    </StackPanel>

                    <Border Grid.Row="3"
                            Padding="18"
                            Background="#F8FAFC"
                            BorderBrush="#E5EAF3"
                            BorderThickness="1"
                            CornerRadius="16">
                        <TextBlock TextWrapping="Wrap"
                                   Classes="Caption"
                                   Text="该示例保留了最小可运行界面，同时具备适合演示和继续产品化的展示结构。你可以在此基础上继续增加导航、日志或更丰富的表单。" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="18">
                <Border Classes="Panel" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="推荐用途" />
                        <TextBlock Classes="Caption" Text="验证 Fluent 主题是否接入正确。" />
                        <TextBlock Classes="Caption" Text="作为开源仓库中的最小可运行界面起步页。" />
                        <TextBlock Classes="Caption" Text="继续扩展为设置页、欢迎页或启动看板。" />
                    </StackPanel>
                </Border>

                <Border Classes="Panel" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="下一步建议" />
                        <TextBlock Classes="Caption" Text="增加导航、状态栏和命令操作区。" />
                        <TextBlock Classes="Caption" Text="补充校验、空状态和加载状态。" />
                        <TextBlock Classes="Caption" Text="继续扩展配色和品牌特征，使其更贴近目标产品。" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

