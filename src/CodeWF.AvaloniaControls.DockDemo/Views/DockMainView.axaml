<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:docViews="clr-namespace:CodeWF.AvaloniaControls.DockDemo.Views.Documents"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="CodeWF.AvaloniaControls.DockDemo.Views.DockMainView"
             x:CompileBindings="True"
             x:DataType="DockControl">
    <DockControl x:Name="DockControl" InitializeLayout="True" InitializeFactory="True">
        <DockControl.Factory>
            <Factory />
        </DockControl.Factory>
        <RootDock DefaultDockable="{Binding #MainLayout}">
            <ProportionalDock x:Name="MainLayout" Id="MainLayout" Orientation="Horizontal">
                <DocumentDock x:Name="DocumentsPane"
                              Id="DocumentsPane"
                              CanCreateDocument="False"
                              ActiveDockable="DataManagementDocument">
                    <Document x:Name="DataManagementDocument"
                              Id="DataManagementDocument"
                              Title="数据管理"
                              CanClose="False">
                        <docViews:DataManagementView />
                    </Document>
                    <Document x:Name="SystemSettingsDocument"
                              Id="SystemSettingsDocument"
                              Title="系统设置"
                              CanClose="False">
                        <docViews:SystemSettingsDocumentView />
                    </Document>
                    <Document x:Name="UserCenterDocument"
                              Id="UserCenterDocument"
                              Title="用户中心"
                              CanClose="False">
                        <ScrollViewer>
                            <StackPanel Margin="20" Spacing="18">
                                <Border Padding="24" Background="#1D4ED8" CornerRadius="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="用户中心" />
                                        <TextBlock Foreground="#DBEAFE"
                                                   Text="以更偏资料卡片的文档视图展示身份、职责和审计可见性信息，适合放在 Dock 工作区中长期保留。" />
                                    </StackPanel>
                                </Border>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                                    <Border Width="88" Height="88" Background="#DBEAFE" CornerRadius="22">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="32"
                                                   FontWeight="Bold"
                                                   Foreground="#1D4ED8"
                                                   Text="CW" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="CodeWF 运维人员" />
                                        <TextBlock Foreground="#475569" Text="负责工作区模块的布局策略、权限控制和发布准备。" />
                                        <WrapPanel Margin="0,8,0,0" ItemHeight="36" ItemWidth="140">
                                            <Border Padding="10,6" Background="#EFF6FF" CornerRadius="999">
                                                <TextBlock Text="管理员权限" />
                                            </Border>
                                            <Border Padding="10,6" Background="#F0FDF4" CornerRadius="999">
                                                <TextBlock Text="已启用双重验证" />
                                            </Border>
                                            <Border Padding="10,6" Background="#FFF7ED" CornerRadius="999">
                                                <TextBlock Text="最近同步于 5 分钟前" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Document>
                    <Document x:Name="LogRecordsDocument"
                              Id="LogRecordsDocument"
                              Title="日志记录"
                              CanClose="False">
                        <ScrollViewer>
                            <StackPanel Margin="20" Spacing="14">
                                <Border Padding="22" Background="#0F172A" CornerRadius="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="日志记录" />
                                        <TextBlock Foreground="#CBD5E1"
                                                   Text="一个更适合运维查看的日志流页面，用于回顾工作区活动、发布检查点和问题轨迹。" />
                                    </StackPanel>
                                </Border>
                                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <TextBlock FontWeight="SemiBold" Text="09:12:44" />
                                            <TextBlock Grid.Column="1" Text="已成功恢复上一次会话中的 Dock 窗口。" />
                                            <Border Grid.Column="2" Padding="8,4" Background="#DCFCE7" CornerRadius="999">
                                                <TextBlock Foreground="#166534" Text="信息" />
                                            </Border>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <TextBlock FontWeight="SemiBold" Text="09:15:08" />
                                            <TextBlock Grid.Column="1" Text="数据导出模块请求打开一个浮动对比文档。" />
                                            <Border Grid.Column="2" Padding="8,4" Background="#FEF3C7" CornerRadius="999">
                                                <TextBlock Foreground="#92400E" Text="警告" />
                                            </Border>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <TextBlock FontWeight="SemiBold" Text="09:17:26" />
                                            <TextBlock Grid.Column="1" Text="工作区布局快照已保存到本地存储。" />
                                            <Border Grid.Column="2" Padding="8,4" Background="#DBEAFE" CornerRadius="999">
                                                <TextBlock Foreground="#1D4ED8" Text="跟踪" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Document>
                    <Document x:Name="HelpDocumentationDocument"
                              Id="HelpDocumentationDocument"
                              Title="帮助文档"
                              CanClose="False">
                        <ScrollViewer>
                            <StackPanel Margin="20" Spacing="14">
                                <Border Padding="22" Background="#0B3B2E" CornerRadius="20">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Text="帮助文档" />
                                        <TextBlock Foreground="#D1FAE5"
                                                   Text="集中介绍外壳结构、停靠手势与可扩展点，方便集成者快速了解整个示例的组织方式。" />
                                    </StackPanel>
                                </Border>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="快速开始" />
                                            <TextBlock Foreground="#475569" Text="打开主要文档，拖出一个页签到新窗口，观察工作区如何跟踪新宿主窗口。" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="开源说明" />
                                            <TextBlock Foreground="#475569" Text="该示例保持在免费依赖链路上，贡献者无需商业附加包即可构建和改造。" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Document>
                </DocumentDock>
            </ProportionalDock>
        </RootDock>
    </DockControl>
</UserControl>

