<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.DockDemo.ViewModels.Documents"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:DataManagementViewModel"
             x:CompileBindings="True"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="CodeWF.AvaloniaControls.DockDemo.Views.Documents.DataManagementView">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="18">
            <Border Padding="24" Background="#0F172A" CornerRadius="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding Title}" />
                        <TextBlock MaxWidth="560"
                                   Foreground="#CBD5E1"
                                   Text="在同一工作区内创建、审阅和调度浮动文档。该示例展示 Dock 文档区如何承载业务工具并保持清晰结构。" />
                    </StackPanel>

                    <Button VerticalAlignment="Top"
                            Padding="18,10"
                            Background="#22C55E"
                            Command="{Binding CreateDocumentHandler}"
                            Content="创建浮动文档"
                            CornerRadius="12"
                            Foreground="#06230F"
                            FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="13" Foreground="#64748B" Text="工作区健康度" />
                        <TextBlock FontSize="26" FontWeight="Bold" Text="99.96%" />
                        <TextBlock Foreground="#475569" Text="过去 24 小时内文档调度的平均成功率。" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="13" Foreground="#64748B" Text="待处理审阅" />
                        <TextBlock FontSize="26" FontWeight="Bold" Text="18" />
                        <TextBlock Foreground="#475569" Text="等待审批或后续处理的文档数量。" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="18" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="13" Foreground="#64748B" Text="自动化规则" />
                        <TextBlock FontSize="26" FontWeight="Bold" Text="7" />
                        <TextBlock Foreground="#475569" Text="绑定在文档流程上的可复用动作数量。" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="18">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="推荐流程" />
                        <Border Padding="14" Background="#F8FAFC" CornerRadius="14">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="1. 录入与分类" />
                                <TextBlock Foreground="#475569" Text="录入新项目、分配负责人，并在发布前标记风险与紧急程度。" />
                            </StackPanel>
                        </Border>
                        <Border Padding="14" Background="#F8FAFC" CornerRadius="14">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="2. 审阅与补充" />
                                <TextBlock Foreground="#475569" Text="直接在当前文档页签中补充附件、备注与审批步骤。" />
                            </StackPanel>
                        </Border>
                        <Border Padding="14" Background="#F8FAFC" CornerRadius="14">
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="3. 发布到下游工具" />
                                <TextBlock Foreground="#475569" Text="在新窗口中打开关联记录，便于对比内容且不打断当前工作。" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="设计说明" />
                        <Border Padding="16" Background="#EEF6FF" CornerRadius="14">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#1E3A8A"
                                       Text="该示例突出主操作，同时预留足够留白，以容纳属性检查区或文档元数据区域。" />
                        </Border>
                        <Border Padding="16" Background="#F8FAFC" CornerRadius="14">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#475569"
                                       Text="为了适配开源分发，该页面仅使用 Avalonia 原生控件，使视觉方案在不同主题下都更易迁移。" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

