<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:CodeWF.AvaloniaControls.DockDemo.ViewModels.Documents"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:SystemSettingsDocumentViewModel"
             x:CompileBindings="True"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="CodeWF.AvaloniaControls.DockDemo.Views.Documents.SystemSettingsDocumentView">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="18">
            <Border Padding="24" Background="#111827" CornerRadius="20">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="{Binding Title}" />
                    <TextBlock MaxWidth="580"
                               Foreground="#CBD5E1"
                               Text="这是一个适合放在 Dock 文档页中的紧凑设置页，兼顾配置项、发布偏好和运行保护。" />
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="14">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="运行偏好" />
                        <CheckBox IsChecked="True" Content="启用启动完整性检查" />
                        <CheckBox IsChecked="True" Content="重新启动时恢复工作区页签" />
                        <CheckBox IsChecked="False" Content="允许预览版集成" />
                        <TextBlock Foreground="#64748B" Text="这些开关演示了适合放在文档页中的持久化外壳选项。" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                    <StackPanel Spacing="14">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="部署配置" />
                        <TextBlock Foreground="#64748B" Text="环境" />
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="生产环境" />
                            <ComboBoxItem Content="预发布环境" />
                            <ComboBoxItem Content="开发环境" />
                        </ComboBox>
                        <TextBlock Foreground="#64748B" Text="主题包" />
                        <TextBox Text="CodeWF 开源主题" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" Background="White" BorderBrush="#DCE3EE" BorderThickness="1" CornerRadius="16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Width="52" Height="52" Background="#DCFCE7" CornerRadius="14">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#166534"
                                   Text="S" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="发布建议" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#475569"
                                   Text="可将该文档页作为功能开关、诊断选项和安全默认值的集中入口，当前视觉结构也便于后续扩展成更完整的管理中心。" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

